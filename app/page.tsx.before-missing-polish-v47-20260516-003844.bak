        <div className="pointer-events-none absolute inset-0 backdrop-blur-[.5px]" />
        <div className="relative w-full max-w-sm rounded-[2.2rem] border border-white/10 bg-white/[.075] p-7 text-center shadow-2xl shadow-black/70 backdrop-blur-3xl">
