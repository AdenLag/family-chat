                title="Add text"
              >
                T
              </button>
              <button
                onClick={() => toggleStoryTool("style")}
                className={"flex h-12 w-12 items-center justify-center rounded-full border border-white/20 text-lg font-black shadow-2xl backdrop-blur-2xl transition active:scale-95 " + (storyTool === "style" && storyOptionsOpen ? "bg-blue-600/80" : "bg-black/25")}
                title="Text color"
              >
                🎨
              </button>
              <button
                onClick={() => toggleStoryTool("manage")}
                className={"flex h-12 w-12 items-center justify-center rounded-full border border-white/20 text-sm font-black shadow-2xl backdrop-blur-2xl transition active:scale-95 " + (storyTool === "manage" && storyOptionsOpen ? "bg-blue-600/80" : "bg-black/25")}
                title="Text styles"
