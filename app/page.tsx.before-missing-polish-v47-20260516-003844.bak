            Family Feud
          </h1>
          <p className="mb-6 text-center text-gray-400">
            {isSignUp ? "Create your account" : "Sign in to your account"}
          </p>

          <button
            onClick={signInWithGoogle}
            className="mb-4 w-full rounded-2xl bg-white p-4 font-black text-black"
          >
            Continue with Google
          </button>

          {isSignUp && (
            <input
              className="mb-3 w-full rounded-2xl bg-zinc-900 p-4 outline-none"
              placeholder="Display name"
              value={name}
              onChange={(e) => setName(e.target.value)}
            />
          )}

          <input
            className="mb-3 w-full rounded-2xl bg-zinc-900 p-4 outline-none"
            placeholder="Email"
            value={email}
            onChange={(e) => setEmail(e.target.value)}
          />
          <input
            className="mb-4 w-full rounded-2xl bg-zinc-900 p-4 outline-none"
            placeholder="Password"
            type="password"
