              {authError}
            </div>
          )}

          <button
            disabled={authBusy}
            onClick={isSignUp ? signUp : signIn}
            className={`mb-4 w-full rounded-2xl p-4 font-black text-white ${bubbleClass(settingsColor)}`}
            style={bubbleStyle(settingsColor)}
          >
            {authBusy ? "Loading..." : isSignUp ? "Create Account" : "Sign In"}
          </button>

          <button
            onClick={() => setIsSignUp(!isSignUp)}
            className="w-full text-gray-400"
          >
            {isSignUp
              ? "Already have an account? Sign in"
              : "Need an account? Sign up"}
          </button>
        </div>
      </main>
    );
  }

  if (screen === "familyGate") {
    return (
      <main
        className={`fixed inset-0 h-[100dvh] overflow-y-auto overscroll-y-contain px-4 pt-[calc(env(safe-area-inset-top)+1.25rem)] pb-[calc(env(safe-area-inset-bottom)+8.5rem)] ${appScaleClass()}`}
        style={scaledPageStyle(homeStyle())}
      >
        <div className="mx-auto min-h-[calc(100dvh+9rem)] max-w-3xl pb-[calc(env(safe-area-inset-bottom)+10rem)]">
          <header className="mb-6 rounded-[2rem] border border-white/10 bg-white/[.08] p-5 shadow-2xl shadow-black/50 backdrop-blur-2xl">
            <div className="flex items-center justify-between gap-4">
              <button
                onClick={() => setScreen("home")}
                className="rounded-2xl bg-black/40 px-4 py-3 font-black"
              >
                ← Back
              </button>
              <h1 className="flex-1 text-center text-3xl font-black">
                Create or Join Family
              </h1>
              <div className="w-20" />
            </div>
          </header>

          <div className="grid gap-5 md:grid-cols-2">
            <div className={`rounded-[2rem] p-5 ${card()}`}>
              <div className="mb-4 text-5xl">🦅</div>
              <h2 className="mb-2 text-3xl font-black">Create Family</h2>
              <p className="mb-5 text-white/55">
                Start a new private Family Feud. You become the owner and admins
                can share the invite code/link.
              </p>
              <input
                className="mb-3 w-full rounded-2xl bg-zinc-950 p-4 outline-none"
                placeholder="Family name"
                value={familyName}
                onChange={(e) => setFamilyName(e.target.value)}
              />
              <button
                onClick={createFamilyServer}
                className={`w-full rounded-2xl p-4 font-black ${bubbleClass(profile?.theme_color || "patriot")}`}
                style={bubbleStyle(profile?.theme_color)}
              >
                Create Family
              </button>
            </div>

            <div className={`rounded-[2rem] p-5 ${card()}`}>
              <div className="mb-4 text-5xl">🔐</div>
              <h2 className="mb-2 text-3xl font-black">Join Family</h2>
              <p className="mb-5 text-white/55">
                Enter the code from a family owner or family admin.
              </p>
              <input
                className="mb-3 w-full rounded-2xl bg-zinc-950 p-4 uppercase tracking-widest outline-none"
                placeholder="Invite code"
                value={familyJoinCode}
                onChange={(e) =>
                  setFamilyJoinCode(e.target.value.toUpperCase())
                }
              />
              <button
                onClick={joinFamilyServer}
                className="w-full rounded-2xl bg-emerald-700 p-4 font-black"
              >
                Join Family
              </button>
            </div>
          </div>
        </div>
      </main>
    );
  }

  if (screen === "home") {
    return (
      <>
      <main
        onClick={() => setOpenMenu(null)}
        className={`fixed inset-0 h-[100dvh] overflow-y-auto overscroll-y-contain px-4 pt-[calc(env(safe-area-inset-top)+1.25rem)] pb-[calc(env(safe-area-inset-bottom)+10rem)] ${appScaleClass()}`}
        style={scaledPageStyle(homeStyle())}
      >
        <div className="mx-auto min-h-[calc(100dvh+8rem)] max-w-3xl pb-[calc(env(safe-area-inset-bottom)+9rem)]">
          <header
            onClick={(e) => e.stopPropagation()}
            className="ff-tight sticky top-[calc(env(safe-area-inset-top)+.75rem)] z-50 relative mb-5 flex items-center gap-4 overflow-visible rounded-[2rem] border border-white/10 px-5 py-4 shadow-2xl shadow-black/50 backdrop-blur-2xl backdrop-saturate-150"
            style={appHeaderStyle()}
          >
            <div className="pointer-events-none absolute inset-0 overflow-hidden rounded-[2rem] bg-[radial-gradient(circle_at_0%_0%,rgba(37,99,235,.26),transparent_38%),radial-gradient(circle_at_100%_0%,rgba(185,28,28,.22),transparent_40%)]" />

            <button
              onClick={(e) => {
                e.stopPropagation();
                setFamilyMenuOpen(!familyMenuOpen);
              }}
              className="relative flex min-w-0 flex-1 items-center gap-3 rounded-[1.5rem] px-1 py-1 text-left transition hover:bg-white/[.04]"
              title="Switch family"
            >
              {appIcon() ? (
                <img
                  src={appIcon()}
                  alt="App icon"
                  className="h-12 w-12 shrink-0 object-contain drop-shadow-2xl"
                />
              ) : (
                <div className="shrink-0 text-5xl drop-shadow-2xl">
                  {APP_ICON}
                </div>
              )}
              <div className="min-w-0 flex-1">
                <h1
                  className={`truncate text-4xl tracking-tight sm:text-5xl ${profile?.title_font || settingsTitleFont || "font-black"}`}
                  style={appTitleStyle()}
                >
                  {currentFamily?.name || "Family Feud"}
                </h1>
                {currentFamily && (
                  <div className="mt-1 truncate text-xs font-bold uppercase tracking-[.18em] text-white/40">
                    Family Feud
                  </div>
                )}
              </div>
              <span
                className={`relative flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/[.06] text-white/70 shadow-inner transition ${familyMenuOpen ? "rotate-180 bg-white/[.12]" : ""}`}
              >
                <svg
                  viewBox="0 0 24 24"
                  className="h-5 w-5"
                  fill="none"
                  stroke="currentColor"
                  strokeWidth="2.5"
                  strokeLinecap="round"
                  strokeLinejoin="round"
                >
                  <path d="m6 9 6 6 6-6" />
                </svg>
              </span>
            </button>

            <button
              onClick={(e) => {
                e.stopPropagation();
                setScreen("settings");
              }}
              className="relative rounded-full border border-white/15 bg-white/10 p-1 shadow-xl backdrop-blur-xl"
              title="Settings"
            >
              <Avatar
                id={userId}
                name={profile?.display_name}
                size="h-12 w-12"
                rounded="rounded-full"
              />
            </button>

            {familyMenuOpen && (
              <div className="absolute left-4 right-4 top-[calc(100%+.5rem)] z-50 overflow-hidden rounded-[1.75rem] border border-white/10 bg-zinc-950/95 p-2 shadow-2xl shadow-black/70 backdrop-blur-2xl">
                <div className="max-h-72 overflow-y-auto pr-1">
                  {familyServers.length ? (
                    familyServers.map((family) => (
                      <button
                        key={family.id}
                        onClick={(e) => {
                          e.stopPropagation();
                          selectFamilyServer(family);
                        }}
                        className={`mb-1 flex w-full items-center gap-3 rounded-2xl p-3 text-left transition ${currentFamily?.id === family.id ? "bg-blue-600/25" : "hover:bg-white/10"}`}
                      >
                        <div className="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-red-600 via-blue-600 to-blue-950 font-black">
                          👥
                        </div>
                        <div className="min-w-0 flex-1">
                          <div className="truncate font-black">
                            {family.name}
                          </div>
                          <div className="truncate text-xs text-white/45">
                            {currentFamily?.id === family.id
                              ? "Current family"
                              : "Switch to this family"}
                          </div>
                        </div>
                        {currentFamily?.id === family.id && (
                          <span className="text-blue-300">✓</span>
                        )}
                      </button>
                    ))
                  ) : (
                    <div className="rounded-2xl bg-white/[.04] p-4 text-sm text-white/55">
                      You are not in a family yet.
                    </div>
                  )}
                </div>
                <button
                  onClick={(e) => {
                    e.stopPropagation();
                    setFamilyMenuOpen(false);
                    setScreen("familyGate");
                  }}
                  className="mt-2 flex w-full items-center gap-3 rounded-2xl border border-dashed border-white/20 bg-white/[.04] p-3 text-left font-black hover:bg-white/10"
                >
                  <div className="flex h-11 w-11 items-center justify-center rounded-2xl bg-white/10 text-2xl">
                    ＋
                  </div>
                  <div>
                    <div>Create or Join Family</div>
                    <div className="text-xs font-medium text-white/45">
                      Use a code or start a new family
                    </div>
                  </div>
                </button>
              </div>
            )}
          </header>

          <div
            className="ff-tight mb-8 flex items-center gap-4 rounded-[1.75rem] border border-white/10 px-5 py-4 shadow-xl shadow-black/30 backdrop-blur-2xl"
            style={homePanelStyle()}
          >
            <span className="text-3xl opacity-70">⌕</span>
            <input
              className="w-full bg-transparent text-2xl font-semibold outline-none placeholder:opacity-45"
              placeholder="Search"
              value={homeSearch}
              onChange={(e) => setHomeSearch(e.target.value)}
            />
            {homeSearch && (
              <button
                onClick={() => setHomeSearch("")}
                className="rounded-full bg-white/10 px-3 py-1 text-xl"
              >
                ×
              </button>
            )}
          </div>

          {activeFamilyDeletePoll && currentFamily && (
            <div className="ff-tight mb-6 rounded-[1.75rem] border border-red-400/30 bg-red-950/35 p-5 shadow-2xl shadow-black/40 backdrop-blur-2xl">
              <div className="flex items-start gap-4">
                <div className="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-red-500/20 text-2xl">
                  🗳️
                </div>
                <div className="min-w-0 flex-1">
                  <div className="text-xl font-black text-red-100">
                    Delete vote active
                  </div>
                  <div className="mt-1 text-sm text-white/60">
                    {familyDeleteYesCount()} yes / {familyMemberTotal()} members
                    · {familyDeletePercent()}% yes · ends{" "}
                    {formatChatTime(activeFamilyDeletePoll.expires_at)}
                  </div>
                  <div className="mt-4 grid grid-cols-2 gap-3">
                    <button
                      onClick={() => voteFamilyDelete("yes")}
                      className="rounded-2xl bg-red-700 p-3 font-black"
                    >
                      Vote Delete
                    </button>
                    <button
                      onClick={() => voteFamilyDelete("no")}
                      className="rounded-2xl bg-zinc-800 p-3 font-black"
                    >
                      Vote Keep
                    </button>
                  </div>
                </div>
              </div>
            </div>
          )}

          {!currentFamily && (
            <div className={`mb-8 rounded-[2rem] p-6 text-center ${card()}`}>
              <div className="mx-auto mb-4 flex h-20 w-20 items-center justify-center rounded-[1.75rem] bg-white/10 text-4xl">
                ＋
              </div>
              <h2 className="mb-2 text-3xl font-black">
                Create or join a family
              </h2>
              <p className="mx-auto mb-5 max-w-md text-white/55">
                You are signed in, but you are not part of any Family Feud yet.
                Create one or join with an invite code to see chats.
              </p>
              <button
                onClick={() => setScreen("familyGate")}
                className={`rounded-2xl px-6 py-4 font-black ${bubbleClass(profile?.theme_color || "patriot")}`}
                style={bubbleStyle(profile?.theme_color)}
              >
                Create / Join Family
              </button>
            </div>
          )}

          {currentFamily && (
            <h2 className="mb-4 text-2xl font-black">👥 Your Chats</h2>
          )}

          {currentFamily && (
            <div
              className="space-y-3"
            >
              {[...chats]
                .filter((chat) => {
                  const q = homeSearch.trim().toLowerCase();
                  if (!q) return true;
                  return (
                    chatTitle(chat).toLowerCase().includes(q) ||
                    homePreview(chat).toLowerCase().includes(q)
                  );
                })
                .sort((a, b) => {
                  if (a.is_family !== b.is_family)
                    return Number(b.is_family) - Number(a.is_family);
                  const q = homeSearch.trim().toLowerCase();
                  if (q) {
                    const at = chatTitle(a).toLowerCase();
                    const bt = chatTitle(b).toLowerCase();
                    const as = at.startsWith(q) ? 0 : at.includes(q) ? 1 : 2;
                    const bs = bt.startsWith(q) ? 0 : bt.includes(q) ? 1 : 2;
                    if (as !== bs) return as - bs;
                  }
                  const al = latestMessageFor(a.id)?.created_at || "";
                  const bl = latestMessageFor(b.id)?.created_at || "";
                  return (
                    new Date(bl || 0).getTime() - new Date(al || 0).getTime()
                  );
                })
                .map((chat) => {
                  const last = latestMessageFor(chat.id);
                  const count = unreadCount(chat.id);
                  const preview = homePreview(chat);

                  return (
                    <div
                      key={chat.id}
                      className="relative overflow-hidden rounded-[1.75rem] border border-white/10 shadow-xl shadow-black/20 backdrop-blur-sm"
                      style={homePanelStyle()}
                    >
                      <button
                        onClick={() => openChat(chat)}
                        className="ff-vpad ff-chatrow flex w-full items-center gap-4 px-4 py-5 text-left transition hover:bg-white/[.04]"
                      >
                        {chat.is_family ? (
                          chat.icon_url ? (
                            <img src={chat.icon_url} alt={chatTitle(chat)} className="h-16 w-16 shrink-0 rounded-full object-cover ring-2 ring-blue-500/60" />
                          ) : (
                            <div
                              className={`flex h-16 w-16 shrink-0 items-center justify-center rounded-full text-3xl font-black text-white ${bubbleClass(chat.chat_color || "patriot")}`}
                              style={bubbleStyle(chat.chat_color)}
                            >
                              👥
                            </div>
                          )
                        ) : chat.direct_key ? (
                          <Avatar
                            id={otherDirectMemberId(chat)}
                            name={chatTitle(chat)}
                            size="h-16 w-16"
                            rounded="rounded-full"
                          />
                        ) : (
                          chat.icon_url ? (
                            <img src={chat.icon_url} alt={chatTitle(chat)} className="h-16 w-16 shrink-0 rounded-full object-cover ring-1 ring-white/15" />
                          ) : (
                            <div
                              className={`flex h-16 w-16 shrink-0 items-center justify-center rounded-full text-3xl font-black text-white ${bubbleClass(chat.chat_color || "patriot")}`}
                              style={bubbleStyle(chat.chat_color)}
                            >
                              💬
                            </div>
                          )
                        )}

                        <div className="min-w-0 flex-1 pb-1">
                          <div className="flex items-center gap-3 pr-28">
                            <div
                              className={`truncate text-2xl ${profile?.chat_name_font || settingsChatNameFont || "font-black"}`}
                            >
                              {chatTitle(chat)}
                            </div>
                          </div>
                          {preview && (
                            <p className="mt-1 truncate pr-28 text-lg font-medium text-white/50">
                              {preview}
                              {last?.user_id === userId ? (
                                <span className="ml-2 text-blue-400">✓✓</span>
                              ) : null}
                            </p>
                          )}
                        </div>
                      </button>

                      <button
                        onClick={(e) => {
                          e.stopPropagation();
                          setOpenMenu(openMenu === chat.id ? null : chat.id);
                        }}
                        className="absolute right-3 top-4 z-10 rounded-xl px-3 py-2 text-xl leading-none text-white/60 hover:bg-white/10"
                      >
                        ⋮
                      </button>

                      {count > 0 && (
                        <div className="pointer-events-none absolute right-14 top-5 flex h-7 min-w-7 items-center justify-center rounded-full bg-blue-600 px-2 text-xs font-black shadow-lg shadow-blue-950/60">
                          {count}
                        </div>
                      )}

                      <div className="pointer-events-none absolute right-5 top-14 text-right text-sm font-semibold leading-none text-white/55">
                        {formatHomeTime(last?.created_at)}
                      </div>

                      {openMenu === chat.id && (
                        <div
                          onClick={(e) => e.stopPropagation()}
                          className="absolute right-3 top-12 z-20 w-52 rounded-2xl border border-white/10 bg-zinc-950 p-2 shadow-2xl"
                        >
                          <button
                            onClick={() => openChatSettings(chat)}
                            className="w-full rounded-xl px-3 py-2 text-left hover:bg-white/10"
                          >
                            Chat settings
                          </button>
                          {!chat.direct_key &&
                            (isAdmin() || isFamilyAdmin()) && (
                              <button
                                onClick={() => copyInvite(chat)}
                                className="w-full rounded-xl px-3 py-2 text-left hover:bg-white/10"
                              >
                                Copy invite link
                              </button>
                            )}
                        </div>
                      )}
                    </div>
                  );
                })}
            </div>
          )}

        </div>
      </main>
      <FixedBottomDock active="home" />
      </>
    );
  }


  if (screen === "stories") {
    const storyGroups = storiesByUser();
    const flatStories = storyGroups.flatMap((group) => group.items);
    const activeStory = activeStoryIndex === null ? null : flatStories[activeStoryIndex] || null;
    const myStories = stories.filter((story) => story.user_id === userId);

    return (
      <>
      <main className={`fixed inset-0 h-[100dvh] overflow-y-auto overscroll-y-contain px-4 pt-[calc(env(safe-area-inset-top)+1.25rem)] pb-[calc(env(safe-area-inset-bottom)+10rem)] text-white ${appScaleClass()}`} style={scaledPageStyle(homeStyle())}>
        <div className="mx-auto min-h-[calc(100dvh+9rem)] max-w-3xl pb-[calc(env(safe-area-inset-bottom)+10rem)]">
          <header className="sticky top-[calc(env(safe-area-inset-top)+.75rem)] z-50 mb-5 rounded-[2rem] border border-white/10 bg-white/[.08] p-5 shadow-2xl shadow-black/50 backdrop-blur-2xl backdrop-saturate-150">
            <div className="flex items-center justify-between gap-4">
              <div>
                <div className="text-xs font-black uppercase tracking-[.2em] text-blue-200/70">{currentFamily?.name || "Family Feud"}</div>
                <h1 className="text-4xl font-black">Stories</h1>
              </div>
            </div>
          </header>

          <div className={`mb-5 rounded-[2rem] p-5 ${card()}`}>
            <div className="flex items-center gap-4">
              <div className="rounded-full bg-gradient-to-br from-blue-400 via-blue-600 to-indigo-900 p-[3px]">
                <Avatar id={userId} name={profile?.display_name} size="h-16 w-16" rounded="rounded-full" />
              </div>
              <div className="min-w-0 flex-1">
                <div className="text-xl font-black">Add to your story</div>
                <p className="text-sm text-white/50">Build a full-screen photo or video story with text, color, filters, and pinch/rotate placement.</p>
              </div>
            </div>

            {!storyDraftUrl ? (
              <label className="mt-5 flex cursor-pointer items-center justify-center rounded-[1.5rem] bg-blue-600 p-5 font-black shadow-xl shadow-blue-950/40 active:scale-[.99]">
                Choose Photo / Video
                <input hidden type="file" accept="image/*,video/*" onChange={(e) => e.target.files?.[0] && createStoryFromFile(e.target.files[0])} />
              </label>
            ) : (
              <div className="mt-5 overflow-hidden rounded-[2rem] border border-white/10 bg-black shadow-2xl shadow-black/60">
                <div className="relative overflow-hidden bg-black">
                  <div className="absolute right-3 top-3 z-30 flex flex-col items-center gap-3">
                    {[
                      ["text", "T"],
                      ["style", "✎"],
                      ["move", "↔"],
                      ["filter", "✦"],
                    ].map(([id, label]) => (
                      <button key={id} onClick={() => setStoryTool(id as any)} className={`flex h-12 w-12 items-center justify-center rounded-full border border-white/20 text-lg font-black shadow-xl backdrop-blur-2xl transition active:scale-95 ${storyTool === id ? "bg-blue-600/80" : "bg-black/20"}`}>
                        {label}
                      </button>
                    ))}
                    <button onClick={clearStoryDraft} className="flex h-12 w-12 items-center justify-center rounded-full border border-white/20 bg-black/20 text-xl font-black shadow-xl backdrop-blur-2xl transition active:scale-95" title="Cancel story">×</button>
                  </div>

                  <div className="min-w-0 p-0">
                    <div className="relative mx-auto flex h-[min(78vh,760px)] min-h-[560px] w-full touch-none select-none items-center justify-center overflow-hidden bg-black">
                      {storyDraftType === "video" ? (
                        <video src={storyDraftUrl} className={`h-full w-full object-cover ${storyFilterClass(storyFilter)}`} controls />
                      ) : (
                        <img src={storyDraftUrl} alt="Story preview" className={`h-full w-full object-cover ${storyFilterClass(storyFilter)}`} />
                      )}
                      {storyOverlayText && (
                        <div onPointerDown={dragStoryOverlay} className="absolute z-20 cursor-grab px-5 active:cursor-grabbing" style={storyOverlayTransformStyle()}>
                          <div className="relative">
                            <div className={`${storyOverlaySize} max-w-[280px] break-words rounded-2xl bg-black/30 px-4 py-2 font-black drop-shadow-2xl backdrop-blur-sm ring-1 ring-white/20`} style={{ color: storyOverlayColor }}>
                              {storyOverlayText}
                            </div>
                            <span className="absolute -left-2 -top-2 h-4 w-4 rounded-full border border-white/80 bg-white/40 shadow" />
                            <span className="absolute -bottom-2 -right-2 h-4 w-4 rounded-full border border-white/80 bg-white/40 shadow" />
                          </div>
                        </div>
                      )}
                    </div>

                    <div className="relative z-30 m-4 rounded-[1.5rem] border border-white/10 bg-zinc-950/80 p-4 shadow-2xl shadow-black/40 backdrop-blur-2xl">
                      {storyTool === "text" && (
                        <div className="space-y-3">
                          <input value={storyOverlayText} onChange={(e) => setStoryOverlayText(e.target.value)} placeholder="Text across the photo/video" className="w-full rounded-2xl bg-white/10 p-4 font-bold outline-none placeholder:text-white/35" />
                          <input value={storyCaption} onChange={(e) => setStoryCaption(e.target.value)} placeholder="Caption under story" className="w-full rounded-2xl bg-white/10 p-4 font-bold outline-none placeholder:text-white/35" />
                        </div>
                      )}
                      {storyTool === "style" && (
                        <div className="space-y-4">
                          <div className="grid grid-cols-6 gap-3">
                            {["#ffffff", "#fde047", "#60a5fa", "#fb7185", "#34d399", "#c084fc", "#000000", "#f97316", "#22d3ee", "#f9a8d4", "#a3e635", "#e5e7eb"].map((color) => (
                              <button key={color} onClick={() => setStoryOverlayColor(color)} className={`h-11 rounded-2xl border-4 ${storyOverlayColor === color ? "border-blue-400" : "border-white/10"}`} style={{ background: color }} />
                            ))}
                          </div>
                          <div className="grid grid-cols-3 gap-3">
                            {[ ["text-2xl", "Small"], ["text-4xl", "Medium"], ["text-6xl", "Huge"] ].map(([value, label]) => (
                              <button key={value} onClick={() => setStoryOverlaySize(value)} className={`rounded-2xl p-4 font-black ${storyOverlaySize === value ? "bg-blue-600" : "bg-white/10"}`}>{label}</button>
                            ))}
                          </div>
                        </div>
                      )}
                      {storyTool === "move" && (
                        <div className="space-y-4">
                          <p className="text-sm font-bold text-white/55">Drag text anywhere on the photo. Use two fingers on the text to pinch bigger/smaller and twist to rotate. Sliders are backup controls.</p>
                          <label className="block text-sm font-black text-white/70">Text size / zoom</label>
                          <input type="range" min="0.6" max="2.2" step="0.05" value={storyOverlayScale} onChange={(e) => setStoryOverlayScale(Number(e.target.value))} className="w-full" />
                          <label className="block text-sm font-black text-white/70">Rotate</label>
                          <input type="range" min="-45" max="45" step="1" value={storyOverlayRotate} onChange={(e) => setStoryOverlayRotate(Number(e.target.value))} className="w-full" />
                          <div className="grid grid-cols-5 gap-2">
                            {[ ["top",50,12], ["left",15,50], ["center",50,50], ["right",85,50], ["bottom",50,88] ].map(([pos,x,y]) => (
                              <button key={String(pos)} onClick={() => { setStoryOverlayPosition(String(pos)); setStoryOverlayX(Number(x)); setStoryOverlayY(Number(y)); }} className={`rounded-2xl p-3 text-sm font-black capitalize ${storyOverlayPosition === pos ? "bg-blue-600" : "bg-white/10"}`}>{String(pos)}</button>
                            ))}
                          </div>
                        </div>
                      )}
                      {storyTool === "filter" && (
                        <div className="grid grid-cols-3 gap-3">
                          {["none", "warm", "cool", "cinema", "mono", "dream"].map((filter) => (
                            <button key={filter} onClick={() => setStoryFilter(filter)} className={`rounded-2xl p-4 font-black capitalize ${storyFilter === filter ? "bg-blue-600" : "bg-white/10"}`}>{filter}</button>
                          ))}
                        </div>
                      )}
                    </div>

                    <div className="relative z-30 m-4 grid grid-cols-2 gap-3">
                      <button onClick={clearStoryDraft} className="rounded-2xl bg-white/10 p-4 font-black">Back out</button>
                      <button onClick={publishStory} className="rounded-2xl bg-blue-600 p-4 font-black shadow-lg shadow-blue-950/40">Post Story</button>
                    </div>
                  </div>
                </div>
              </div>
            )}
            {formNotice && <div className="mt-3 rounded-2xl bg-white/10 p-3 text-sm font-bold text-white/75">{formNotice}</div>}
          </div>

          <div className="space-y-3">
            {storyGroups.length ? storyGroups.map((group) => {
              const first = group.items[0];
              const flatIndex = flatStories.findIndex((story) => story.id === first.id);
              return (
                <button key={group.user_id} onClick={() => openStoryIndex(flatIndex)} className="flex w-full items-center gap-4 rounded-[1.75rem] border border-white/10 bg-white/[.07] p-4 text-left shadow-xl shadow-black/20 backdrop-blur-xl active:scale-[.99]">
                  <div className={`${hasUnseenStory(group.user_id) ? "bg-blue-500" : "bg-white/20"} rounded-full p-[3px]`}>
                    <Avatar id={group.user_id} name={profileName(group.user_id)} size="h-16 w-16" rounded="rounded-full" />
                  </div>
                  <div className="min-w-0 flex-1">
                    <div className="truncate text-xl font-black">{group.user_id === userId ? "Your story" : profileName(group.user_id)}</div>
                    <div className="text-sm text-white/45">{group.items.length} update{group.items.length === 1 ? "" : "s"} · newest expires in 24h</div>
                  </div>
                  <div className="text-2xl text-white/40">›</div>
                </button>
              );
            }) : (
              <div className="rounded-[2rem] border border-white/10 bg-white/[.06] p-8 text-center text-white/55">No stories yet. Be the first to post one.</div>
            )}
          </div>
        </div>

        {storyPosting && (
          <div className="fixed left-1/2 top-24 z-[120] flex -translate-x-1/2 items-center gap-3 rounded-full border border-white/15 bg-black/60 px-4 py-3 text-sm font-black shadow-2xl shadow-black/60 backdrop-blur-2xl">
            <span className="h-3 w-3 animate-pulse rounded-full bg-blue-400" />
            Posting your story...
          </div>
        )}

        {activeStory && (() => {
          const isMine = activeStory.user_id === userId;
          const currentIndex = activeStoryIndex || 0;
          const goPrevious = (event: React.MouseEvent<HTMLButtonElement>) => {
            event.stopPropagation();
            if (currentIndex <= 0) return;
            setActiveStoryIndex(currentIndex - 1);
          };
          const goNext = (event: React.MouseEvent<HTMLButtonElement>) => {
            event.stopPropagation();
            if (currentIndex >= flatStories.length - 1) return;
            setActiveStoryIndex(currentIndex + 1);
          };

          return (
            <div className="fixed inset-0 z-[100] flex flex-col bg-black/95 text-white" style={{ transform: "scale(" + (1 / appScaleValue()) + ")", transformOrigin: "top left", width: (appScaleValue() * 100) + "%", height: (appScaleValue() * 100) + "vh" }}>
              <header className="relative z-20 flex shrink-0 items-start gap-3 px-4 pb-3 pt-[calc(env(safe-area-inset-top)+.85rem)]">
                <Avatar id={activeStory.user_id} name={profileName(activeStory.user_id)} size="h-12 w-12" rounded="rounded-full" />
                <div className="min-w-0 flex-1">
                  <div className="font-black leading-tight">{profileName(activeStory.user_id)}</div>
                  <div className="text-xs text-white/45">{formatChatTime(activeStory.created_at)}</div>
                  {activeStory.caption && (
                    <div className="mt-2 max-w-full whitespace-normal break-words pr-2 text-xl font-black leading-snug text-white">
                      {activeStory.caption}
                    </div>
                  )}
                </div>
                <button onClick={() => setActiveStoryIndex(null)} className="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-white/10 text-2xl font-black backdrop-blur-xl active:scale-95">×</button>
              </header>

              <section className="relative flex min-h-0 flex-1 items-center justify-center px-4 pb-3">
                <button onClick={goPrevious} className="absolute left-0 top-0 z-30 h-full w-[4mm]" aria-label="Previous story" />
                <button onClick={goNext} className="absolute right-0 top-0 z-30 h-full w-[4mm]" aria-label="Next story" />

                <div className="relative flex max-h-full w-full max-w-3xl items-center justify-center overflow-hidden rounded-[2rem] bg-black">
                  {activeStory.media_type === "video" ? (
                    <video src={activeStory.media_url} className={`max-h-full max-w-full rounded-[2rem] object-contain ${storyFilterClass(activeStory.filter_name)}`} controls autoPlay />
                  ) : (
                    <button
                      onClick={(e) => {
                        e.stopPropagation();
                        setGalleryItems([{ url: activeStory.media_url, name: "Story photo", type: "image" }]);
                      }}
                      className="flex max-h-full max-w-full items-center justify-center"
                      aria-label="View story photo"
                    >
                      <img src={activeStory.media_url} alt="Story" className={`max-h-full max-w-full rounded-[2rem] object-contain shadow-2xl ${storyFilterClass(activeStory.filter_name)}`} />
                    </button>
                  )}
                  {readStoryTextItems(activeStory).map((item) => (
                    <div key={item.id} className="pointer-events-none absolute z-20 px-5" style={storyTextItemStyle(item)}>
                      <div className={"max-w-[300px] break-words bg-transparent px-2 py-1 text-5xl " + storyTextDisplayClass(item.style)} style={storyTextDisplayStyle(item)}>
                        {item.text}
                      </div>
                    </div>
                  ))}
                </div>
              </section>

              {isMine && (
                <div className="grid shrink-0 grid-cols-2 gap-3 px-4 pb-[calc(env(safe-area-inset-bottom)+1rem)]">
                  <button onClick={(e) => { e.stopPropagation(); editStoryCaption(activeStory); }} className="rounded-2xl bg-white/10 p-4 font-black backdrop-blur-xl active:scale-[.98]">Edit</button>
                  <button onClick={(e) => { e.stopPropagation(); deleteStory(activeStory.id); setActiveStoryIndex(null); }} className="rounded-2xl bg-red-600/90 p-4 font-black shadow-lg shadow-red-950/40 active:scale-[.98]">Delete</button>
                </div>
              )}
            </div>
          );
        })()}
      </main>
      <FixedBottomDock active="stories" />
      </>
    );
  }

  if (screen === "newChat") {
    const grouped = groupedNewChatProfiles();
    const letters = Object.keys(grouped).sort();

    return (
      <main
        className={`fixed inset-0 h-[100dvh] overflow-y-auto overscroll-y-contain px-4 pt-[calc(env(safe-area-inset-top)+1.25rem)] pb-[calc(env(safe-area-inset-bottom)+8rem)] ${appScaleClass()}`}
        style={scaledPageStyle(homeStyle())}
      >
        <div className="mx-auto min-h-[calc(100dvh+8rem)] max-w-3xl pb-[calc(env(safe-area-inset-bottom)+9rem)]">
          <div className="relative mb-5 rounded-[2rem] border border-white/10 bg-white/[.08] p-5 shadow-2xl shadow-black/50 backdrop-blur-2xl">
            <button
              onClick={() => setScreen("home")}
              className="absolute left-5 top-4 flex h-12 w-12 items-center justify-center rounded-full border border-white/10 bg-white/10 text-2xl font-black"
              title="Back"
            >
              ←
            </button>
            <h1 className="text-center text-3xl font-black">New Message</h1>
          </div>

          <div className="mb-5 grid grid-cols-2 gap-3">
            <button
              onClick={() => setNewChatMode("direct")}
              className={`rounded-2xl p-4 font-black ${newChatMode === "direct" ? bubbleClass() : "bg-zinc-900/80"}`}
            >
              Direct Message
            </button>
            <button
              onClick={() => setNewChatMode("group")}
              className={`rounded-2xl p-4 font-black ${newChatMode === "group" ? bubbleClass() : "bg-zinc-900/80"}`}
            >
              Create Group
            </button>
          </div>

          {newChatMode === "group" && (
            <input
              className="mb-5 w-full rounded-2xl bg-zinc-900/90 p-4 outline-none"
              placeholder="Group chat name"
              value={newChatName}
              onChange={(e) => setNewChatName(e.target.value)}
            />
          )}

          <div className="sticky top-3 z-10 mb-6 flex items-center gap-3 rounded-[1.75rem] border border-white/10 bg-zinc-900/90 px-5 py-4 shadow-xl backdrop-blur-2xl">
            <span className="text-3xl text-white/70">⌕</span>
            <input
              className="w-full bg-transparent text-xl font-semibold outline-none placeholder:text-white/45"
              placeholder="Name, username, or number"
              value={newChatSearch}
              onChange={(e) => setNewChatSearch(e.target.value)}
            />
          </div>

          {!letters.length && (
            <div className="rounded-[1.75rem] border border-white/10 bg-white/[.08] p-6 text-center backdrop-blur-xl">
              <div className="text-4xl">👥</div>
              <div className="mt-3 text-2xl font-black">No family members found yet</div>
              <p className="mt-2 text-white/55">Only people who joined this Family Feud can be added to chats. Share your family invite code first, then refresh.</p>
              <button
                onClick={refreshFamilyPeople}
                className="mt-5 rounded-2xl bg-blue-700 px-5 py-3 font-black"
              >
                Refresh family people
              </button>
            </div>
          )}

          <div className="space-y-8">
            {letters.map((letter) => (
              <section key={letter}>
                <h2 className="mb-3 px-4 text-2xl font-black text-white/85">
                  {letter}
                </h2>
                <div className="overflow-hidden rounded-[1.75rem] border border-white/10 bg-white/[.08] backdrop-blur-xl">
                  {grouped[letter].map((p) => {
                    const selected = selectedPeople.includes(p.id);

                    return (
                      <div
                        key={p.id}
                        className="flex items-center justify-between gap-3 border-b border-white/10 px-5 py-4 last:border-b-0"
                      >
                        <button
                          onClick={() =>
                            newChatMode === "direct" && openDirectChat(p.id)
                          }
                          className="flex min-w-0 flex-1 items-center gap-4 text-left"
                        >
                          <Avatar
                            id={p.id}
                            name={p.display_name}
                            size="h-14 w-14"
                            rounded="rounded-full"
                          />
                          <div className="min-w-0">
                            <div className="truncate text-2xl font-semibold">
                              {profileName(p.id)}
                            </div>
                          </div>
                        </button>

                        {newChatMode === "group" && (
                          <button
                            onClick={() => {
                              if (selected)
                                setSelectedPeople(
                                  selectedPeople.filter((id) => id !== p.id),
                                );
                              else {
                                if (selectedPeople.length >= 39)
                                  return alert("Max 40 people.");
                                setSelectedPeople([...selectedPeople, p.id]);
                              }
                            }}
                            className={`flex h-10 w-10 items-center justify-center rounded-full border text-2xl font-black ${
                              selected
                                ? "border-blue-400 bg-blue-600 text-white"
                                : "border-white/20 bg-white/5 text-transparent"
                            }`}
                          >
                            ✓
                          </button>
                        )}
                      </div>
                    );
                  })}
                </div>
              </section>
            ))}
          </div>

          {newChatMode === "group" && (
            <button
              onClick={createGroupChat}
              className={`fixed bottom-[calc(env(safe-area-inset-bottom)+1.35rem)] left-4 right-4 z-50 mx-auto max-w-3xl rounded-2xl p-4 font-black shadow-2xl ${bubbleClass()}`}
            >
              Create Group Chat
            </button>
          )}
        </div>
      </main>
    );
  }

  if (screen === "settings") {
    const SettingButton = ({
      label,
      sub,
      icon,
      go,
    }: {
      label: string;
      sub?: string;
      icon: string;
      go: typeof settingsSection;
    }) => (
      <button
        onClick={() => setSettingsSection(go)}
        className="w-full rounded-[1.5rem] border border-white/10 bg-white/[.08] p-5 text-left shadow-xl shadow-black/20 backdrop-blur-xl transition hover:bg-white/[.13]"
      >
        <div className="flex items-center gap-4">
          <div className="flex h-12 w-12 items-center justify-center rounded-2xl bg-white/10 text-2xl">
            {icon}
          </div>
          <div className="min-w-0 flex-1">
            <div className="text-xl font-black">{label}</div>
            {sub && (
              <div className="mt-1 truncate text-sm text-white/50">{sub}</div>
            )}
          </div>
          <div className="text-2xl text-white/40">›</div>
        </div>
      </button>
    );

    const SettingsBack = ({ title }: { title: string }) => (
      <>
        <button
          onClick={() => setSettingsSection("main")}
          className="mb-5 rounded-2xl bg-black/60 px-4 py-3 font-bold"
        >
          ← Settings
        </button>
        <h1 className="mb-6 text-4xl font-black">{title}</h1>
      </>
    );

    return (
      <main
        className={`fixed inset-0 h-[100dvh] overflow-y-auto overscroll-y-contain px-5 pt-[calc(env(safe-area-inset-top)+1.25rem)] pb-[calc(env(safe-area-inset-bottom)+8rem)] text-white ${appScaleClass()}`}
        style={scaledPageStyle()}
      >
        <div className="mx-auto min-h-[calc(100dvh+8rem)] max-w-3xl pb-[calc(env(safe-area-inset-bottom)+9rem)]">
          {settingsSection === "main" && (
            <>
              <button
                onClick={() => setScreen("home")}
                className="mb-6 rounded-2xl bg-black/60 px-4 py-3 font-bold"
              >
                ← Back
              </button>
              <h1 className="mb-6 text-5xl font-black">Settings</h1>

              <div className="mb-5 rounded-[2rem] border border-white/10 bg-black/55 p-5 backdrop-blur-xl">
                <div className="flex items-center gap-4">
                  {settingsAvatar ? (
                    <div className="h-20 w-20 overflow-hidden rounded-3xl border border-white/20 bg-black shadow-2xl shadow-black/50">
                      <img
                        src={settingsAvatar}
                        alt="Your profile icon"
                        className="h-full w-full object-cover"
                      />
                    </div>
                  ) : (
                    <div
                      className={`flex h-20 w-20 items-center justify-center rounded-3xl text-2xl font-black ${bubbleClass(settingsColor)}`}
                    >
                      {initials(settingsName)}
                    </div>
                  )}
                  <div>
                    <div className="text-sm text-white/50">Signed in as</div>
                    <div className="text-2xl font-black">
                      {profile?.display_name}
                    </div>
                  </div>
                </div>
              </div>

              {currentFamily && (
                <div className="mb-3 rounded-[1.5rem] border border-blue-400/20 bg-blue-500/10 p-4">
                  <div className="text-xs font-black uppercase tracking-[.18em] text-blue-100/70">Family invite link</div>
                  <div className="mt-2 break-all text-sm font-bold text-white/75">{`${typeof window !== "undefined" ? window.location.origin : APP_URL}?invite=${currentFamily.invite_code}`}</div>
                  <button
                    onClick={() => navigator.clipboard.writeText(`${window.location.origin}?invite=${currentFamily.invite_code}`)}
                    className="mt-3 rounded-xl bg-blue-600 px-4 py-2 text-sm font-black transition active:scale-95 active:brightness-125"
                  >
                    Copy Family Link
                  </button>
                </div>
              )}

              <div className="space-y-3">
                <SettingButton
                  icon="👤"
                  label="Profile"
                  sub="Name, profile picture, nickname"
                  go="profile"
                />
                <SettingButton
                  icon="✨"
                  label="Preset looks"
                  sub="Original, Signal, Royal Gold, Neon, Ice"
                  go="presets"
                />
                <SettingButton
                  icon="🏠"
                  label="Home screen"
                  sub="Wallpaper, blur, text color, card color"
                  go="home"
                />
                <SettingButton
                  icon="💬"
                  label="Default chat look"
                  sub="Default wallpaper and bubble color"
                  go="chatDefault"
                />
                <SettingButton
                  icon="🔎"
                  label="Display size"
                  sub="Make everything smaller or larger on your screen"
                  go="display"
                />
                {isAppAdmin() && (
                  <SettingButton
                    icon="🦅"
                    label="App bar"
                    sub="Admin: header, title, app icon, fonts"
                    go="appBar"
                  />
                )}
                <SettingButton
                  icon="📷"
                  label="Permissions"
                  sub="Camera and photo permission"
                  go="permissions"
                />
                {isAppAdmin() && (
                  <SettingButton
                    icon="🛡️"
                    label="App admin"
                    sub="Remove, block, unblock users"
                    go="admin"
                  />
                )}
              </div>

              {currentFamily && isFamilyAdmin() && (
                <div className="mt-6 space-y-3 rounded-[2rem] border border-red-500/20 bg-red-950/20 p-4">
                  <div className="text-sm font-bold uppercase tracking-[.18em] text-red-200/70">
                    Family Feud controls
                  </div>
                  <button
                    onClick={startFamilyDeleteVote}
                    className="w-full rounded-2xl bg-red-800 p-4 font-black text-red-100"
                  >
                    Start 24-hour Delete Vote
                  </button>
                  {activeFamilyDeletePoll && (
                    <div className="rounded-2xl bg-black/35 p-3 text-sm text-white/65">
                      Active vote: {familyDeleteYesCount()} yes /{" "}
                      {familyMemberTotal()} members · {familyDeletePercent()}%
                    </div>
                  )}
                </div>
              )}

              <div className="mt-6 space-y-3 rounded-[2rem] border border-red-500/20 bg-red-950/20 p-4">
                <button
                  onClick={deleteMyAccount}
                  className="w-full rounded-2xl bg-red-950 p-4 font-black text-red-200"
                >
                  Delete My Account Data
                </button>
                {signOutConfirmOpen && (
                  <div className="mb-3 rounded-[1.5rem] border border-red-400/25 bg-zinc-950/95 p-4 text-left shadow-2xl shadow-black/50 backdrop-blur-2xl">
                    <div className="flex items-start gap-3">
                      <div className="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-red-500/15 text-lg">
                        !
                      </div>
                      <div className="min-w-0 flex-1">
                        <div className="text-lg font-black">Sign out?</div>
                        <p className="mt-1 text-sm font-bold leading-relaxed text-white/55">
                          Are you sure you want to sign out?
                        </p>
                      </div>
                    </div>
                    <div className="mt-4 grid grid-cols-2 gap-3">
                      <button
                        onClick={() => setSignOutConfirmOpen(false)}
                        className="rounded-2xl bg-white/10 p-3 font-black text-white/80 active:scale-[.98]"
                      >
                        Cancel
                      </button>
                      <button
                        onClick={confirmSignOut}
                        className="rounded-2xl bg-red-600 p-3 font-black text-white shadow-lg shadow-red-950/40 active:scale-[.98]"
                      >
                        Sign Out
                      </button>
                    </div>
                  </div>
                )}

                <button
                  onClick={signOut}
                  className="w-full rounded-2xl bg-red-700 p-4 font-black active:scale-[.98]"
                >
                  Sign Out
                </button>
              </div>
            </>
          )}

          {settingsSection === "profile" && (
            <div className={`rounded-[2rem] p-5 ${card()}`}>
              <SettingsBack title="Profile" />
              <div className="mb-5 rounded-2xl bg-black/50 p-4">
                <div className="text-sm text-white/50">Email</div>
                <div className="break-all font-bold">
                  {userEmail || profile?.email || "No email found"}
                </div>
              </div>
              <label className="block font-bold">Profile icon / picture</label>
              <input
                className="mt-2 w-full rounded-2xl bg-black p-4"
                type="file"
                accept="image/*"
                onChange={(e) =>
                  e.target.files?.[0] &&
                  uploadImage(e.target.files[0], setSettingsAvatar)
                }
              />
              {settingsAvatar && (
                <button
                  onClick={() => setSettingsAvatar(null)}
                  className="mt-3 rounded-xl bg-zinc-800 px-4 py-2 text-sm font-bold"
                >
                  Remove picture
                </button>
              )}
              <label className="mt-6 block font-bold">Your display name</label>
              <input
                className="mt-2 w-full rounded-2xl bg-black p-4"
                value={settingsName}
                onChange={(e) => setSettingsName(e.target.value)}
              />
              <label className="mt-6 block font-bold">About</label>
              <textarea
                className="mt-2 min-h-[96px] w-full resize-none rounded-2xl bg-black p-4 outline-none"
                value={settingsAbout}
                onChange={(e) => setSettingsAbout(e.target.value)}
                placeholder="Ready to feud"
              />
              <button
                onClick={saveProfileSettings}
                className={`mt-8 w-full rounded-2xl p-4 font-black ${bubbleClass(settingsColor)}`}
              >
                Save Profile
              </button>
            </div>
          )}

          {settingsSection === "presets" && (
            <div className={`rounded-[2rem] p-5 ${card()}`}>
              <SettingsBack title="Preset Looks" />
              <div className="grid gap-3 sm:grid-cols-2">
                {lookPresets.map((preset) => (
                  <button
                    key={preset.id}
                    onClick={() => applyLookPreset(preset.id)}
                    className="rounded-2xl border border-white/10 bg-white/10 p-5 text-left font-black hover:bg-white/15"
                  >
                    {preset.name}
                  </button>
                ))}
              </div>
              <button
                onClick={saveProfileSettings}
                className={`mt-8 w-full rounded-2xl p-4 font-black ${bubbleClass(settingsColor)}`}
              >
                Save Preset
              </button>
            </div>
          )}

          {settingsSection === "home" && (
            <div className={`rounded-[2rem] p-5 ${card()}`}>
              <SettingsBack title="Home Screen" />
              <label className="block font-bold">Home background</label>
              <div className="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-5">
                {backgrounds.map((bg) => (
                  <button
                    key={bg.id}
                    onClick={() => setSettingsHomeBackground(bg.id)}
                    className={`h-20 rounded-2xl border transition ${settingsHomeBackground === bg.id ? "border-yellow-300 ring-4 ring-yellow-300/40" : "border-white/10"}`}
                    style={{ background: bg.css }}
                    title={bg.name}
                  />
                ))}
              </div>
              <input
                className="mt-4 w-full rounded-2xl bg-black p-4"
                type="file"
                accept="image/*"
                onChange={(e) =>
                  e.target.files?.[0] &&
                  uploadImage(e.target.files[0], setSettingsHomeBackground)
                }
              />
              <label className="mt-6 block font-bold">
                Home wallpaper blur: {settingsHomeBlur}px
              </label>
              <input
                type="range"
                min="0"
                max="18"
                value={settingsHomeBlur}
                onChange={(e) => setSettingsHomeBlur(Number(e.target.value))}
                className="w-full"
              />
              <div className="mt-6 grid grid-cols-2 gap-3">
                <label className="font-bold">
                  Home text color
                  <input
                    type="color"
                    className="mt-2 h-12 w-full rounded-xl bg-black p-1"
                    value={settingsHomeTextColor}
                    onChange={(e) => setSettingsHomeTextColor(e.target.value)}
                  />
                </label>
                <label className="font-bold">
                  Home card color
                  <input
                    type="color"
                    className="mt-2 h-12 w-full rounded-xl bg-black p-1"
                    value={settingsHomePanelColor}
                    onChange={(e) => setSettingsHomePanelColor(e.target.value)}
                  />
                </label>
              </div>
              <button
                onClick={saveProfileSettings}
                className={`mt-8 w-full rounded-2xl p-4 font-black ${bubbleClass(settingsColor)}`}
              >
                Save Home Screen
              </button>
            </div>
          )}

          {settingsSection === "chatDefault" && (
            <div className={`rounded-[2rem] p-5 ${card()}`}>
              <SettingsBack title="Default Chat Look" />
              <label className="block font-bold">Default chat background</label>
              <div className="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-5">
                {backgrounds.map((bg) => (
                  <button
                    key={bg.id}
                    onClick={() => setSettingsBackground(bg.id)}
                    className={`h-20 rounded-2xl border transition ${settingsBackground === bg.id ? "border-yellow-300 ring-4 ring-yellow-300/40" : "border-white/10"}`}
                    style={{ background: bg.css }}
                    title={bg.name}
                  />
                ))}
              </div>
              <input
                className="mt-4 w-full rounded-2xl bg-black p-4"
                type="file"
                accept="image/*"
                onChange={(e) =>
                  e.target.files?.[0] &&
                  uploadImage(e.target.files[0], setSettingsBackground)
                }
              />
              <label className="mt-6 block font-bold">
                Default message color
              </label>
              <div className="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-4">
                {themes.map((t) => (
                  <button
                    key={t.id}
                    onClick={() => setSettingsColor(t.id)}
                    className={`h-14 rounded-2xl border bg-gradient-to-r transition ${settingsColor === t.id ? "border-yellow-300 ring-4 ring-yellow-300/40" : "border-white/10"} ${t.cls}`}
                  >
                    {settingsColor === t.id ? "✓" : ""}
                  </button>
                ))}
              </div>
              <button
                onClick={saveProfileSettings}
                className={`mt-8 w-full rounded-2xl p-4 font-black ${bubbleClass(settingsColor)}`}
              >
                Save Default Chat Look
              </button>
            </div>
          )}

          {settingsSection === "display" && (
            <div className={`rounded-[2rem] p-5 ${card()}`}>
              <SettingsBack title="Display Size" />
              <p className="mb-5 text-white/60">
                This only changes how the app looks on your device.
              </p>
              <label className="block font-bold">Whole app size</label>
              <select
                className="mt-2 w-full rounded-2xl bg-black p-4"
                value={settingsAppScale}
                onChange={(e) => setSettingsAppScale(e.target.value)}
              >
                <option value="tiny">Tiny / fits the most</option>
                <option value="small">Small</option>
                <option value="normal">Normal</option>
                <option value="large">Large</option>
                <option value="huge">Huge / easiest to see</option>
              </select>
              <button
                onClick={saveProfileSettings}
                className={`mt-8 w-full rounded-2xl p-4 font-black ${bubbleClass(settingsColor)}`}
              >
                Save Display Size
              </button>
            </div>
          )}

          {false && settingsSection === "appBar" && (
            <div className={`rounded-[2rem] p-5 ${card()}`}>
              <SettingsBack title="App Bar" />
              {isAppAdmin() ? (
                <>
                  <label className="block font-bold">
                    App name, admin only
                  </label>
                  <input
                    className="mt-2 w-full rounded-2xl bg-black p-4"
                    value={settingsAppName}
                    onChange={(e) => setSettingsAppName(e.target.value)}
                  />
                  <label className="mt-6 block font-bold">
                    Transparent app icon PNG, admin only
                  </label>
                  <input
                    className="mt-2 w-full rounded-2xl bg-black p-4"
                    type="file"
                    accept="image/png,image/*"
                    onChange={(e) =>
                      e.target.files?.[0] &&
                      uploadImage(e.target.files[0], setSettingsAppIcon)
                    }
                  />
                  {settingsAppIcon && (
                    <button
                      onClick={() => setSettingsAppIcon(null)}
                      className="mt-3 rounded-xl bg-zinc-800 px-4 py-2 text-sm font-bold"
                    >
                      Use default eagle
                    </button>
                  )}
                </>
              ) : (
                <div className="rounded-2xl bg-black/50 p-4 text-sm text-white/60">
                  Only the app admin can change the app name and icon.
                </div>
              )}
              <div className="mt-6 grid grid-cols-2 gap-3">
                <label className="font-bold">
                  Bar color
                  <input
                    type="color"
                    className="mt-2 h-12 w-full rounded-xl bg-black p-1"
                    value={
                      settingsHeaderColor.startsWith("#")
                        ? settingsHeaderColor
                        : "#1f2937"
                    }
                    onChange={(e) => setSettingsHeaderColor(e.target.value)}
                  />
                </label>
                <label className="font-bold">
                  Title text color
                  <input
                    type="color"
                    className="mt-2 h-12 w-full rounded-xl bg-black p-1"
                    value={settingsTitleColor}
                    onChange={(e) => setSettingsTitleColor(e.target.value)}
                  />
                </label>
              </div>
              <label className="mt-6 block font-bold">
                Family Feud title font
              </label>
              <select
                className="mt-2 w-full rounded-2xl bg-black p-4"
                value={settingsTitleFont}
                onChange={(e) => setSettingsTitleFont(e.target.value)}
              >
                <option value="font-black">Bold premium</option>
                <option value="font-serif italic font-bold">Fancy serif</option>
                <option value="font-mono font-bold">Tech / gaming</option>
              </select>
              <label className="mt-6 block font-bold">
                Home chat name font
              </label>
              <select
                className="mt-2 w-full rounded-2xl bg-black p-4"
                value={settingsChatNameFont}
                onChange={(e) => setSettingsChatNameFont(e.target.value)}
              >
                <option value="font-black">Bold premium</option>
                <option value="font-serif font-bold">Serif</option>
                <option value="font-mono font-bold">Tech / gaming</option>
              </select>
              <button
                onClick={saveProfileSettings}
                className={`mt-8 w-full rounded-2xl p-4 font-black ${bubbleClass(settingsColor)}`}
              >
                Save App Bar
              </button>
            </div>
          )}

          {settingsSection === "permissions" && (
            <div className={`rounded-[2rem] p-5 ${card()}`}>
              <SettingsBack title="Permissions" />
              <div className="grid grid-cols-2 gap-3">
                <button
                  onClick={requestCameraPermission}
                  className="rounded-2xl bg-white/10 p-4 font-black"
                >
                  📷 Allow Camera
                </button>
                <button
                  onClick={() =>
                    requestPhotoPermission("settings-photo-permission")
                  }
                  className="rounded-2xl bg-white/10 p-4 font-black"
                >
                  🖼️ Allow Photos
                </button>
                <button
                  onClick={requestMicrophonePermission}
                  className="rounded-2xl bg-white/10 p-4 font-black"
                >
                  Mic Permission
                </button>
              </div>
              <input
                id="settings-photo-permission"
                className="hidden"
                type="file"
                accept="image/*"
              />
            </div>
          )}

          {false && settingsSection === "admin" && isAppAdmin() && (
            <div className={`rounded-[2rem] p-5 ${card()}`}>
              <SettingsBack title="App Admin" />
              <div className="space-y-3">
                {profiles
                  .filter((p) => p.id !== userId)
                  .map((p) => (
                    <div
                      key={p.id}
                      className="flex flex-wrap items-center justify-between gap-2 rounded-2xl bg-black/50 p-3"
                    >
                      <div>
                        <div className="font-black">{p.display_name}</div>
                        <div className="text-xs text-white/45">
                          {p.email || p.id}
                        </div>
                      </div>
                      <div className="flex flex-wrap gap-2">
                        <button
                          onClick={() => removeUserFromApp(p.id)}
                          className="rounded-xl bg-orange-700 px-3 py-2 text-sm font-bold"
                        >
                          Remove
                        </button>
                        {p.is_blocked ? (
                          <button
                            onClick={() => unblockUser(p.id)}
                            className="rounded-xl bg-green-700 px-3 py-2 text-sm font-bold"
                          >
                            Unblock
                          </button>
                        ) : (
                          <button
                            onClick={() => blockUser(p.id)}
                            className="rounded-xl bg-red-800 px-3 py-2 text-sm font-bold"
                          >
                            Block
                          </button>
                        )}
                      </div>
                    </div>
                  ))}
              </div>
            </div>
          )}
        </div>
      </main>
    );
  }

  if (screen === "chatSettings" && activeChat) {
    const canManageChatInfo =
      isAdmin() || (activeChat.is_family && isFamilyAdmin());
    const canCustomizeLook = true;
    const isDirect = !!activeChat.direct_key;
    const directOtherId = isDirect ? otherDirectMemberId(activeChat) : null;
    const familyUserIds = new Set(
      familyMembers
        .filter((m) => m.family_id === currentFamily?.id)
        .map((m) => m.user_id),
    );
    const peopleInChat = profiles.filter((p) => isMember(p.id));
    const peopleNotInChat = isDirect
      ? []
      : profiles.filter((p) => familyUserIds.has(p.id) && !isMember(p.id));

    const ChatSettingButton = ({
      label,
      sub,
      icon,
      go,
    }: {
      label: string;
      sub?: string;
      icon: string;
      go: typeof chatSettingsSection;
    }) => (
      <button
        onClick={() => setChatSettingsSection(go)}
        className="w-full rounded-[1.5rem] border border-white/10 bg-white/[.08] p-5 text-left shadow-xl shadow-black/20 backdrop-blur-xl transition hover:bg-white/[.13]"
      >
        <div className="flex items-center gap-4">
          <div className="flex h-12 w-12 items-center justify-center rounded-2xl bg-white/10 text-2xl">
            {icon}
          </div>
          <div className="min-w-0 flex-1">
            <div className="text-xl font-black">{label}</div>
            {sub && (
              <div className="mt-1 truncate text-sm text-white/50">{sub}</div>
            )}
          </div>
          <div className="text-2xl text-white/40">›</div>
        </div>
      </button>
    );

    const ChatBack = ({ title }: { title: string }) => (
      <>
        <button
          onClick={() => setChatSettingsSection("main")}
          className="mb-5 rounded-2xl bg-black/60 px-4 py-3 font-bold"
        >
          ← Chat Settings
        </button>
        <h1 className="mb-6 text-4xl font-black">{title}</h1>
      </>
    );

    return (
      <main
        className={`fixed inset-0 h-[100dvh] overflow-y-auto overscroll-y-contain px-5 pt-[calc(env(safe-area-inset-top)+1.25rem)] pb-[calc(env(safe-area-inset-bottom)+8rem)] text-white ${appScaleClass()}`}
        style={scaledPageStyle()}
      >
        <div className="mx-auto max-w-4xl pb-28">
          {chatSettingsSection === "main" && (
            <>
              <button
                onClick={() => setScreen("chat")}
                className="mb-6 rounded-2xl bg-black/60 px-4 py-3 font-bold"
              >
                ← Back
              </button>
              <h1 className="mb-6 text-5xl font-black">Chat Settings</h1>
              <div className={`mb-5 rounded-[2rem] p-5 ${card()}`}>
                <h2 className="text-3xl font-black">
                  {isDirect
                    ? directOtherId
                      ? profileName(directOtherId)
                      : chatTitle(activeChat)
                    : chatName}
                </h2>
                {isDirect && directOtherId && (
                  <p className="mt-2 text-white/50">{profileAbout(directOtherId)}</p>
                )}
                {!isDirect && chatDescription && (
                  <p className="mt-2 text-white/50">{chatDescription}</p>
                )}
              </div>
              <div className="space-y-3">
                <ChatSettingButton
                  icon="ℹ️"
                  label={isDirect ? "Nickname" : "Chat info"}
                  sub={
                    isDirect
                      ? "Change the name only you see"
                      : "Name and description"
                  }
                  go="info"
                />
                <ChatSettingButton
                  icon="🎨"
                  label="Message look"
                  sub="Bubbles, text colors, input box"
                  go="look"
                />
                <ChatSettingButton
                  icon="🖼️"
                  label="Wallpaper"
                  sub="Background image, presets, blur"
                  go="wallpaper"
                />
                {!isDirect && (
                  <ChatSettingButton
                    icon="👥"
                    label="Members"
                    sub="Admins, owner, remove members"
                    go="members"
                  />
                )}
                {canManageChatInfo && !isDirect && (
                  <ChatSettingButton
                    icon="➕"
                    label="Add people"
                    sub="Invite existing users"
                    go="addPeople"
                  />
                )}
              </div>
              <div className="mt-6 space-y-3 rounded-[2rem] border border-white/10 bg-black/55 p-4 backdrop-blur-xl">
                {!activeChat.direct_key && (isAdmin() || isFamilyAdmin()) && (
                  <button
                    onClick={() => copyInvite(activeChat)}
                    className="w-full rounded-2xl bg-zinc-900 p-4 font-bold"
                  >
                    🔗 Share Invite Link
                  </button>
                )}
                {activeChat.is_family && (isAdmin() || isFamilyAdmin()) && (
                  <div className="rounded-2xl bg-black/50 p-4 text-sm text-white/70">
                    Family code:{" "}
                    <span className="font-black tracking-widest text-white">
                      {currentFamily?.invite_code || activeChat.invite_code}
                    </span>
                  </div>
                )}
                {activeChat.is_family && isFamilyAdmin() && (
                  <button
                    onClick={startFamilyDeleteVote}
                    className="w-full rounded-2xl bg-red-800 p-4 font-black text-red-100"
                  >
                    Start 24-hour Delete Vote
                  </button>
                )}
                {activeChat.is_family && activeFamilyDeletePoll && (
                  <div className="rounded-2xl border border-red-400/20 bg-red-950/25 p-4 text-sm text-white/70">
                    Delete vote active:{" "}
                    <span className="font-black text-white">
                      {familyDeleteYesCount()} yes / {familyMemberTotal()}{" "}
                      members · {familyDeletePercent()}%
                    </span>
                    <div className="mt-3 grid grid-cols-2 gap-2">
                      <button
                        onClick={() => voteFamilyDelete("yes")}
                        className="rounded-xl bg-red-700 p-2 font-black"
                      >
                        Vote Delete
                      </button>
                      <button
                        onClick={() => voteFamilyDelete("no")}
                        className="rounded-xl bg-zinc-800 p-2 font-black"
                      >
                        Vote Keep
                      </button>
                    </div>
                  </div>
                )}
                {!activeChat.is_family && !activeChat.direct_key && (
                  <button
                    onClick={leaveChat}
                    className="w-full rounded-2xl bg-orange-700 p-4 font-black"
                  >
                    Leave Chat
                  </button>
                )}
                {!activeChat.is_family &&
                  (activeChat.direct_key || isOwner()) && (
                    <button
                      onClick={deleteChat}
                      className="w-full rounded-2xl bg-red-800 p-4 font-black"
                    >
                      Delete Chat Forever
                    </button>
                  )}
              </div>
            </>
          )}

          {chatSettingsSection === "info" && (
            <div className={`rounded-[2rem] p-5 ${card()}`}>
              <ChatBack title={isDirect ? "Nickname" : "Chat Info"} />
              <label className="block font-bold">
                {isDirect ? "Nickname for this person" : "Chat name"}
              </label>
              {isDirect ? (
                <input
                  className="mt-2 w-full rounded-2xl bg-black p-4"
                  placeholder={
                    directOtherId ? profileName(directOtherId) : "Nickname"
                  }
                  value={directNickname}
                  onChange={(e) => setDirectNickname(e.target.value)}
                />
              ) : (
                <input
                  disabled={!canManageChatInfo}
                  className="mt-2 w-full rounded-2xl bg-black p-4 disabled:opacity-50"
                  value={chatName}
                  onChange={(e) => setChatName(e.target.value)}
                />
              )}
              {!isDirect && (
                <>
                  <label className="mt-6 block font-bold">Description</label>
                  <textarea
                    disabled={!canManageChatInfo}
                    className="mt-2 min-h-24 w-full rounded-2xl bg-black p-4 disabled:opacity-50"
                    value={chatDescription}
                    onChange={(e) => setChatDescription(e.target.value)}
                  />
                </>
              )}
              {!isDirect && canManageChatInfo && (
                <div className="mt-6 rounded-2xl border border-white/10 bg-black/35 p-4">
                  <label className="block font-bold">Chat icon / family picture</label>
                  <p className="mt-1 text-sm text-white/45">Family admins can change the main Family Chat icon here. This updates the family picture for everyone.</p>
                  <input
                    className="mt-3 w-full rounded-2xl bg-black p-4"
                    type="file"
                    accept="image/*"
                    onChange={(e) => e.target.files?.[0] && uploadImage(e.target.files[0], setChatIcon)}
                  />
                  {chatIcon && (
                    <div className="mt-3 flex items-center gap-3">
                      <img src={chatIcon} alt="Chat icon preview" className="h-16 w-16 rounded-2xl object-cover" />
                      <button onClick={() => setChatIcon(null)} className="rounded-xl bg-zinc-800 px-4 py-2 text-sm font-black">Remove icon</button>
                    </div>
                  )}
                </div>
              )}
              {isDirect ? (
                <button
                  onClick={saveDirectNickname}
                  className={`mt-8 w-full rounded-2xl p-4 font-black ${bubbleClass(chatColor)}`}
                  style={bubbleStyle(chatColor)}
                >
                  Save Nickname
                </button>
              ) : (
                <button
                  onClick={saveChatSettings}
                  className={`mt-8 w-full rounded-2xl p-4 font-black ${bubbleClass(chatColor)}`}
                  style={bubbleStyle(chatColor)}
                >
                  {canManageChatInfo ? "Save Chat Info" : "Save My Look"}
                </button>
              )}
            </div>
          )}

          {chatSettingsSection === "look" && (
            <div className={`rounded-[2rem] p-5 ${card()}`}>
              <ChatBack title="Message Look" />
              <label className="block font-bold">
                Preset looks for this chat
              </label>
              <div className="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-3">
                {lookPresets.map((preset) => (
                  <button
                    key={preset.id}
                    disabled={!canCustomizeLook}
                    onClick={() => applyChatLookPreset(preset.id)}
                    className="rounded-2xl border border-white/10 bg-white/10 p-3 text-left font-black hover:bg-white/15 disabled:opacity-50"
                  >
                    {preset.name}
                  </button>
                ))}
              </div>
              <p className="mt-3 text-xs text-white/50">
                Saved only for you. Other people will not see your personal
                colors.
              </p>
              <label className="mt-6 block font-bold">
                Message bubble color
              </label>
              <div className="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-4">
                {themes.map((t) => (
                  <button
                    key={t.id}
                    disabled={!canCustomizeLook}
                    onClick={() => setChatColor(t.id)}
                    className={`h-14 rounded-2xl border bg-gradient-to-r transition disabled:opacity-50 ${chatColor === t.id ? "border-yellow-300 ring-4 ring-yellow-300/40" : "border-white/10"} ${t.cls}`}
                  >
                    {chatColor === t.id ? "✓" : ""}
                  </button>
                ))}
              </div>
              <label className="mt-6 block font-bold">
                Custom sent bubble color
              </label>
              <input
                type="color"
                value={customColor}
                disabled={!canCustomizeLook}
                onChange={(e) => {
                  setCustomColor(e.target.value);
                  setChatColor("custom");
                }}
                className="mt-2 h-16 w-full rounded-2xl bg-black p-2 disabled:opacity-50"
              />
              <div className="mt-6 grid grid-cols-2 gap-3">
                <label className="font-bold">
                  Sent text
                  <input
                    type="color"
                    className="mt-2 h-12 w-full rounded-xl bg-black p-1"
                    value={ownTextColor}
                    disabled={!canCustomizeLook}
                    onChange={(e) => setOwnTextColor(e.target.value)}
                  />
                </label>
                <label className="font-bold">
                  Received bubble
                  <input
                    type="color"
                    className="mt-2 h-12 w-full rounded-xl bg-black p-1"
                    value={inboundBubbleColor}
                    disabled={!canCustomizeLook}
                    onChange={(e) => setInboundBubbleColor(e.target.value)}
                  />
                </label>
                <label className="font-bold">
                  Received text
                  <input
                    type="color"
                    className="mt-2 h-12 w-full rounded-xl bg-black p-1"
                    value={inboundTextColor}
                    disabled={!canCustomizeLook}
                    onChange={(e) => setInboundTextColor(e.target.value)}
                  />
                </label>
                <label className="font-bold">
                  Typing box background
                  <input
                    type="color"
                    className="mt-2 h-12 w-full rounded-xl bg-black p-1"
                    value={messageInputBg}
                    disabled={!canCustomizeLook}
                    onChange={(e) => setMessageInputBg(e.target.value)}
                  />
                </label>
                <label className="font-bold">
                  Typing text
                  <input
                    type="color"
                    className="mt-2 h-12 w-full rounded-xl bg-black p-1"
                    value={messageInputText}
                    disabled={!canCustomizeLook}
                    onChange={(e) => setMessageInputText(e.target.value)}
                  />
                </label>
              </div>
              <button
                onClick={saveChatSettings}
                className={`mt-8 w-full rounded-2xl p-4 font-black ${bubbleClass(chatColor)}`}
                style={bubbleStyle(chatColor)}
              >
                Save Message Look
              </button>
            </div>
          )}

          {chatSettingsSection === "wallpaper" && (
            <div className={`rounded-[2rem] p-5 ${card()}`}>
              <ChatBack title="Wallpaper" />
              <label className="block font-bold">
                Wallpaper for this chat only
              </label>
              <div className="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-5">
                {backgrounds.map((bg) => (
                  <button
                    key={bg.id}
                    disabled={!canCustomizeLook}
                    onClick={() => setChatBackground(bg.id)}
                    className={`h-20 rounded-2xl border transition disabled:opacity-50 ${chatBackground === bg.id ? "border-yellow-300 ring-4 ring-yellow-300/40" : "border-white/10"}`}
                    style={{ background: bg.css }}
                    title={bg.name}
                  />
                ))}
              </div>
              <input
                disabled={!canCustomizeLook}
                className="mt-4 w-full rounded-2xl bg-black p-4 disabled:opacity-50"
                type="file"
                accept="image/*"
                onChange={(e) =>
                  e.target.files?.[0] &&
                  uploadImage(e.target.files[0], setChatBackground)
                }
              />
              <label className="mt-6 block font-bold">
                Wallpaper blur: {wallpaperBlur}px
              </label>
              <input
                disabled={!canCustomizeLook}
                type="range"
                min="0"
                max="18"
                value={wallpaperBlur}
                onChange={(e) => setWallpaperBlur(Number(e.target.value))}
                className="w-full disabled:opacity-50"
              />
              <button
                onClick={saveChatSettings}
                className={`mt-8 w-full rounded-2xl p-4 font-black ${bubbleClass(chatColor)}`}
                style={bubbleStyle(chatColor)}
              >
                Save Wallpaper
              </button>
            </div>
          )}

          {chatSettingsSection === "members" && !isDirect && (
            <div className={`rounded-[2rem] p-5 ${card()}`}>
              <ChatBack title="Members" />
              <div className="space-y-3">
                {peopleInChat.map((p) => {
                  const role = roleOf(p.id);
                  return (
                    <div
                      key={p.id}
                      className="flex flex-wrap items-center justify-between gap-2 rounded-2xl bg-black/50 p-3"
                    >
                      <div className="flex items-center gap-3">
                        <Avatar
                          id={p.id}
                          name={profileName(p.id)}
                          size="h-12 w-12"
                        />
                        <div>
                          <div className="font-black">{profileName(p.id)}</div>
                          <div className="text-sm text-gray-400">{role}</div>
                        </div>
                      </div>
                      <div className="flex flex-wrap gap-2">
                        {isOwner() &&
                          p.id !== userId &&
                          role !== "admin" &&
                          role !== "owner" && (
                            <button
                              onClick={() => makeAdmin(p.id)}
                              className="rounded-xl bg-blue-700 px-3 py-2 text-sm font-bold"
                            >
                              Add Admin
                            </button>
                          )}
                        {isOwner() && p.id !== userId && role === "admin" && (
                          <button
                            onClick={() => removeAdmin(p.id)}
                            className="rounded-xl bg-zinc-800 px-3 py-2 text-sm font-bold"
                          >
                            Remove Admin
                          </button>
                        )}
                        {isOwner() &&
                          p.id !== userId &&
                          !activeChat.is_family && (
                            <button
                              onClick={() => transferOwner(p.id)}
                              className="rounded-xl bg-yellow-600 px-3 py-2 text-sm font-bold"
                            >
                              Make Owner
                            </button>
                          )}
                        {canManageChatInfo &&
                          !activeChat.is_family &&
                          p.id !== userId &&
                          (isOwner() || role === "member") && (
                            <button
                              onClick={() => removePersonFromChat(p.id)}
                              className="rounded-xl bg-red-700 px-3 py-2 text-sm font-bold"
                            >
                              Remove
                            </button>
                          )}
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          )}

          {chatSettingsSection === "addPeople" &&
            canManageChatInfo &&
            !isDirect && (
              <div className={`rounded-[2rem] p-5 ${card()}`}>
                <ChatBack title="Add People" />
                <div className="space-y-3">
                  {!peopleNotInChat.length && (
                    <div className="rounded-2xl bg-black/45 p-5 text-center text-white/60">
                      Everyone in this Family Feud is already in this chat, or nobody else has joined yet. Share the Family code first, then tap Refresh.
                      <button onClick={refreshFamilyPeople} className="mt-4 w-full rounded-2xl bg-blue-700 p-3 font-black text-white">Refresh people</button>
                    </div>
                  )}
                  {peopleNotInChat.map((p) => (
                    <div
                      key={p.id}
                      className="flex items-center justify-between rounded-2xl bg-black/50 p-3"
                    >
                      <div className="font-black">{p.display_name}</div>
                      <button
                        onClick={() => addPersonToChat(p.id)}
                        className={`rounded-xl px-4 py-2 font-bold ${bubbleClass(chatColor)}`}
                      >
                        Add
                      </button>
                    </div>
                  ))}
                </div>
              </div>
            )}
        </div>
      </main>
    );
  }

  return (
    <main
      className={`fixed inset-0 flex h-[100dvh] flex-col overflow-hidden text-white ${appScaleClass()}`}
      style={scaledChatStyle()}
    >
      <header className="shrink-0 border-b border-white/10 bg-black/75 px-4 pb-4 pt-[calc(env(safe-area-inset-top)+1rem)] backdrop-blur-2xl backdrop-saturate-150">
        <div className="mx-auto flex max-w-6xl items-center justify-between gap-3">
          <div className="flex min-w-0 items-center gap-3">
            <button
              onClick={() => {
                setScreen("home");
                loadChats();
              }}
              className="shrink-0 text-2xl text-gray-300"
            >
              ←
            </button>
            {activeChat?.direct_key && (
              <Avatar
                id={otherDirectMemberId(activeChat)}
                name={chatTitle(activeChat)}
                size="h-12 w-12"
                rounded="rounded-full"
              />
            )}
            <div className="min-w-0">
              <h1 className="truncate text-2xl font-black">
                {chatTitle(activeChat)}
              </h1>
              {activeChat?.direct_key && otherDirectMemberId(activeChat) && (
                <p className="truncate text-sm text-gray-400">
                  {profileAbout(otherDirectMemberId(activeChat))}
                </p>
              )}
              {activeChat && !activeChat.direct_key && chatSubtitle(activeChat) && (
                <p className="truncate text-sm text-gray-400">
                  {chatSubtitle(activeChat)}
                </p>
              )}
            </div>
          </div>

          <button
            onClick={() => activeChat && openChatSettings(activeChat)}
            className="rounded-2xl bg-zinc-900/90 px-4 py-3 text-xl font-bold"
          >
            ⋮
          </button>
        </div>
      </header>

      <section className="flex-1 overflow-y-auto overscroll-y-contain p-4 pb-[calc(env(safe-area-inset-bottom)+7rem)]">
        <div className="mx-auto max-w-6xl space-y-4">
          {messages.map((msg) => {
            const mine = isOwnMessage(msg);
            const system = !!msg.system_type;
            const hasAudioAttachment = messageAttachments(msg).some((item) =>
              item.type?.startsWith("audio/"),
            );

            if (system && activeChat?.direct_key) return null;

            if (system) {
              return (
                <div key={msg.id} className="flex justify-center">
                  <div className="rounded-full bg-black/60 px-4 py-2 text-sm text-gray-300">
                    {msg.message}
                  </div>
                </div>
              );
            }

            return (
              <div
                key={msg.id}
                className={`flex ${mine ? "justify-end" : "justify-start"}`}
              >
                <div
                  className={`relative max-w-[82%] rounded-3xl px-5 py-3 pr-12 shadow-2xl ${mine ? `${bubbleClass(activeLook().chatColor)} rounded-br-md` : "rounded-bl-md"}`}
                  style={
                    mine
                      ? {
                          ...bubbleStyle(activeLook().chatColor),
                          color: activeLook().ownTextColor,
                        }
                      : {
                          background: activeLook().inboundBubbleColor,
                          color: activeLook().inboundTextColor,
                        }
                  }
                >
                  {!activeChat?.direct_key && !mine && (
                    <div className="mb-1 text-sm font-bold opacity-70">
                      {profileName(msg.user_id)}
                    </div>
                  )}

                  {editingId === msg.id ? (
                    <div className="flex gap-2">
                      <input
                        className="rounded-xl bg-black p-2 outline-none"
                        value={editingText}
                        onChange={(e) => setEditingText(e.target.value)}
                      />
                      <button
                        onClick={() => editMessage(msg.id)}
                        className="rounded-xl bg-green-700 px-3"
                      >
                        Save
                      </button>
                    </div>
                  ) : (
                    <>
                      {messageAttachments(msg).length > 0 &&
                        (() => {
                          const items = messageAttachments(msg);
                          const { visible, extra } =
                            visibleAttachmentGrid(items);
                          const imagesOnly = items.every((item) =>
                            item.type?.startsWith("image/"),
                          );
                          if (imagesOnly) {
                            return (
                              <button
                                onClick={() => setGalleryItems(items)}
                                className="mb-3 grid max-w-[15rem] grid-cols-3 gap-1 text-left"
                              >
                                {visible.map((item, index) => (
                                  <div
                                    key={`${item.name}-${index}`}
                                    className="relative h-20 w-20 overflow-hidden rounded-xl bg-black/40"
                                  >
                                    <img
                                      src={item.url}
                                      alt={item.name}
                                      className="h-full w-full object-cover"
                                    />
                                    {extra > 0 && index === 5 && (
                                      <div className="absolute inset-0 flex items-center justify-center bg-black/60 text-lg font-black backdrop-blur-sm">
                                        +{extra}
                                      </div>
                                    )}
                                  </div>
                                ))}
                              </button>
                            );
                          }
                          return (
                            <div className="mb-3 max-w-full space-y-2 overflow-hidden">
                              {items.map((item, index) =>
                                item.type?.startsWith("audio/") ? (
                                  <div
                                    key={`${item.name}-${index}`}
                                    className="rounded-2xl bg-black/30 p-3"
                                  >
                                    <div className="mb-2 text-xs font-black uppercase tracking-[.2em] text-white/50">
                                      Voice message
                                    </div>
                                    <audio controls src={item.url} className="w-full" />
                                  </div>
                                ) : item.type?.startsWith("video/") ? (
                                  <video
                                    key={`${item.name}-${index}`}
                                    src={item.url}
                                    controls
                                    className="max-h-80 w-full rounded-2xl bg-black/50"
                                  />
                                ) : (
                                  <a
                                    key={`${item.name}-${index}`}
                                    href={item.url}
                                    download={item.name || "attachment"}
                                    className="block max-w-full overflow-hidden break-all rounded-2xl bg-black/30 p-3 text-sm font-bold underline"
                                  >
                                    File: {item.name || "Download attachment"}
                                  </a>
                                ),
                              )}
                            </div>
                          );
                        })()}
                      {msg.message && (
                        <p
                          className={`break-words text-lg ${msg.deleted_at ? "italic opacity-70" : ""}`}
                        >
                          {msg.message}
                        </p>
                      )}
                      <div
                        className={`mt-1 flex items-center justify-end gap-1 text-xs ${mine && messageWasRead(msg) ? "text-red-300" : "opacity-60"}`}
                      >
                        {msg.edited_at && !msg.deleted_at && (
                          <span>edited</span>
                        )}
                        <span>{formatChatTime(msg.created_at)}</span>
                        {mine && <span className="text-sm">✓✓</span>}
                      </div>
                    </>
                  )}

                  {mine && !msg.deleted_at && editingId !== msg.id && (
                    <>
                      <button
                        onClick={(e) => {
                          e.stopPropagation();
                          setOpenMenu(
                            openMenu === `msg-${msg.id}`
                              ? null
                              : `msg-${msg.id}`,
                          );
                        }}
                        className="absolute right-2 top-2 rounded-full px-2 py-1 text-sm opacity-70 hover:bg-black/20"
                      >
                        ⋮
                      </button>
                      {openMenu === `msg-${msg.id}` && (
                        <div
                          onClick={(e) => e.stopPropagation()}
                          className="absolute right-2 top-10 z-30 w-52 rounded-2xl border border-white/10 bg-zinc-950 p-2 text-sm text-white shadow-2xl"
                        >
                          <button
                            onClick={() => {
                              setEditingId(msg.id);
                              setEditingText(msg.message);
                              setOpenMenu(null);
                            }}
                            className="w-full rounded-xl px-3 py-2 text-left hover:bg-white/10"
                          >
                            Edit
                          </button>
                          <button
                            onClick={() => {
                              deleteMessage(msg);
                              setOpenMenu(null);
                            }}
                            className="w-full rounded-xl px-3 py-2 text-left text-red-300 hover:bg-white/10"
                          >
                            Delete
                          </button>
                          <div className="border-t border-white/10 px-3 py-2 text-xs text-white/60">
                            {readByNames(msg)}
                          </div>
                        </div>
                      )}
                    </>
                  )}
                </div>
              </div>
            );
          })}

          {typingUsers.length > 0 && (
            <div className="text-sm text-gray-300">
              {typingUsers.map((u) => u.display_name).join(", ")} typing...
            </div>
          )}

          <div ref={bottomRef} />
        </div>
      </section>

      {galleryItems && (
        <div className="fixed inset-0 z-50 overflow-y-auto bg-black/95 p-4 text-white">
          <div className="mx-auto max-w-3xl">
            <button
              onClick={() => setGalleryItems(null)}
              className="sticky top-4 z-10 mb-4 rounded-2xl bg-white/10 px-4 py-3 font-black backdrop-blur"
            >
              Close
            </button>
            <div className="grid gap-3">
              {galleryItems.map((item, index) => (
                <img
                  key={`${item.name}-${index}`}
                  src={item.url}
                  alt={item.name}
                  className="w-full rounded-3xl object-contain"
                />
              ))}
            </div>
          </div>
        </div>
      )}

      {previewAttachment && (
        <div className="fixed inset-0 z-[70] flex items-center justify-center bg-black/92 p-4 text-white backdrop-blur-xl">
          <div className="w-full max-w-3xl rounded-[2rem] border border-white/10 bg-zinc-950/95 p-4 shadow-2xl shadow-black/60">
            <div className="mb-4 flex items-center justify-between gap-3">
              <div className="min-w-0">
                <div className="truncate text-lg font-black">{previewAttachment.name}</div>
                <div className="text-xs font-bold text-white/45">Preview before sending</div>
              </div>
              <button
                onClick={() => setPreviewAttachment(null)}
                className="rounded-2xl bg-white/10 px-4 py-3 font-black active:scale-[.98]"
              >
                Close
              </button>
            </div>

            {previewAttachment.type.startsWith("image/") ? (
              <img
                src={previewAttachment.url}
                alt={previewAttachment.name}
                className="max-h-[70dvh] w-full rounded-3xl object-contain"
              />
            ) : previewAttachment.type.startsWith("video/") ? (
              <video
                src={previewAttachment.url}
                controls
                className="max-h-[70dvh] w-full rounded-3xl bg-black"
              />
            ) : previewAttachment.type.startsWith("audio/") ? (
              <div className="rounded-3xl bg-white/5 p-5">
                <div className="mb-3 text-sm font-black uppercase tracking-[.2em] text-white/45">
                  Voice message
                </div>
                <audio controls src={previewAttachment.url} className="w-full" />
              </div>
            ) : (
              <a
                href={previewAttachment.url}
                download={previewAttachment.name || "attachment"}
                className="block rounded-3xl bg-white/10 p-5 font-black underline"
              >
                Open file
              </a>
            )}
          </div>
        </div>
      )}

      <footer className="shrink-0 border-t border-white/10 bg-black/80 px-3 pb-[calc(env(safe-area-inset-bottom)+.75rem)] pt-3 backdrop-blur-2xl backdrop-saturate-150">
        <div className="mx-auto max-w-6xl">
          {(pendingAttachments.length > 0 || failedDraft) && (
            <div className="mb-2 rounded-2xl border border-white/10 bg-black/60 p-3">
              {pendingAttachments.length > 0 && (
                <div className="flex flex-wrap gap-2">
                  {pendingAttachments.map((item, index) => (
                    <div
                      key={`${item.name}-${index}`}
                      className="relative h-20 w-20 overflow-hidden rounded-xl bg-white/10"
                    >
                      {item.url && item.type.startsWith("image/") ? (
                        <button
                          type="button"
                          onClick={() =>
                            setPreviewAttachment({ url: item.url, name: item.name, type: item.type })
                          }
                          className="block h-full w-full"
                          title="Preview photo"
                        >
                          <img
                            src={item.url}
                            alt={item.name}
                            className={`h-full w-full object-cover ${item.progress < 100 ? "blur-sm" : ""}`}
                          />
                        </button>
                      ) : item.url && item.type.startsWith("video/") ? (
                        <button
                          type="button"
                          onClick={() =>
                            setPreviewAttachment({ url: item.url, name: item.name, type: item.type })
                          }
                          className="flex h-full w-full items-center justify-center p-2 text-center text-xs font-black"
                          title="Preview video"
                        >
                          Video
                        </button>
                      ) : item.url && item.type.startsWith("audio/") ? (
                        <div className="flex h-full w-full flex-col items-center justify-center gap-1 p-2 text-center">
                          <button
                            type="button"
                            onClick={() =>
                              setPreviewAttachment({ url: item.url, name: item.name, type: item.type })
                            }
                            className="rounded-full bg-white/15 px-2 py-1 text-[10px] font-black"
                            title="Listen before sending"
                          >
                            Play
                          </button>
                          <span className="text-[10px] font-black text-white/70">Voice</span>
                        </div>
                      ) : (
                        <button
                          type="button"
                          onClick={() =>
                            item.url && setPreviewAttachment({ url: item.url, name: item.name, type: item.type })
                          }
                          className="flex h-full w-full items-center justify-center p-2 text-center text-xs break-all"
                          title="Preview file"
                        >
                          File
                        </button>
                      )}
                      {item.progress < 100 && (
                        <div className="absolute inset-0 flex items-center justify-center bg-black/30">
                          <div className="h-9 w-9 animate-spin rounded-full border-4 border-white/20 border-t-white" />
                        </div>
                      )}
                      <button
                        onClick={() =>
                          setPendingAttachments((prev) =>
                            prev.filter((_, i) => i !== index),
                          )
                        }
                        className="absolute right-1 top-1 flex h-5 w-5 items-center justify-center rounded-full bg-black/70 text-xs"
                      >
                        ×
                      </button>
                    </div>
                  ))}
                </div>
              )}
              {voiceNotice && (
                <div className="mt-2 rounded-2xl bg-white/10 px-3 py-2 text-sm font-bold text-white/75">
                  {voiceNotice}
                </div>
              )}
              {failedDraft && (
                <div className="mt-2 flex items-center justify-between gap-3 text-red-200">
                  <span className="font-bold">Failed to send.</span>
                  <button
                    onClick={retryFailedMessage}
                    className="rounded-xl bg-red-700 px-4 py-2 font-black"
                  >
                    Retry
                  </button>
                </div>
              )}
            </div>
          )}
          <div className="flex items-center gap-2">
            <input
              id="message-camera-input"
              className="sr-only"
              type="file"
              accept="image/*"
              capture="environment"
              onChange={(e) => {
                if (e.currentTarget.files?.length)
                  attachMessageFiles(e.currentTarget.files);
                e.currentTarget.value = "";
              }}
            />
            <input
              id="message-photo-input"
              className="sr-only"
              type="file"
              multiple
              accept="image/*,video/*,.pdf,.doc,.docx,.txt,.csv,.xlsx,.xls,.ppt,.pptx,.zip"
              onChange={(e) => {
                if (e.currentTarget.files?.length)
                  attachMessageFiles(e.currentTarget.files);
                e.currentTarget.value = "";
              }}
            />
            <label
              htmlFor="message-camera-input"
              className="flex h-10 w-10 shrink-0 cursor-pointer touch-manipulation select-none items-center justify-center rounded-full bg-white/10 text-xl active:scale-95"
              title="Take photo"
            >
              📷
            </label>
            <label
              htmlFor="message-photo-input"
              className="flex h-10 w-10 shrink-0 cursor-pointer touch-manipulation select-none items-center justify-center rounded-full bg-white/10 text-2xl active:scale-95"
              title="Attach photo or file"
            >
              ＋
            </label>
            <input
              className="min-w-0 flex-1 rounded-2xl p-4 outline-none"
              style={{
                background: activeLook().messageInputBg,
                color: activeLook().messageInputText,
              }}
              placeholder="Type a message..."
              value={message}
              onChange={(e) => {
                setMessage(e.target.value);
                startTyping(e.target.value);
              }}
              onKeyDown={(e) => {
                if (e.key === "Enter" && !e.shiftKey && !sendingMessage)
                  sendMessage();
              }}
            />

            <button
              type="button"
              onPointerDown={startVoiceRecording}
              onPointerUp={stopVoiceRecording}
              onPointerCancel={cancelVoiceRecording}
              onPointerLeave={(event) => {
                if (isRecordingVoice) stopVoiceRecording(event);
              }}
              disabled={sendingMessage}
              className={`flex h-12 w-12 shrink-0 touch-none select-none items-center justify-center rounded-2xl border border-white/10 text-xs font-black shadow-lg shadow-black/30 active:scale-[.96] ${isRecordingVoice ? "bg-red-600 text-white animate-pulse" : "bg-white/10 text-white/80"}`}
              title="Hold to record voice"
            >
              {isRecordingVoice ? "REC" : "Mic"}
            </button>

            <button
              disabled={sendingMessage}
              onClick={sendMessage}
              className={`flex h-12 w-14 shrink-0 items-center justify-center rounded-2xl text-2xl font-black disabled:opacity-60 ${bubbleClass(activeLook().chatColor)}`}
              style={bubbleStyle(activeLook().chatColor)}
            >
              {sendingMessage ? "✓" : "➤"}
            </button>
          </div>
        </div>
      </footer>
    </main>
  );
}
