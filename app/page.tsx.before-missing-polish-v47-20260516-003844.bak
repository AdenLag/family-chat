              </div>
            ))}

            <div className="absolute right-3 top-[max(1rem,env(safe-area-inset-top))] z-40 flex flex-col items-center gap-3" onClick={(e) => e.stopPropagation()}>
              <button
                onClick={() => toggleStoryTool("text")}
