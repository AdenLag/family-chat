"use client";

import { useEffect, useRef, useState } from "react";
import type { CSSProperties } from "react";
import { supabase } from "./supabase";

type Screen =
  | "auth"
  | "familyGate"
  | "home"
  | "stories"
  | "chat"
  | "newChat"
  | "settings"
  | "chatSettings";

type Profile = {
  id: string;
  display_name: string;
  email?: string | null;
  about?: string | null;
  is_blocked?: boolean | null;
  home_text_color?: string | null;
  home_panel_color?: string | null;
  home_wallpaper_blur?: number | null;
  theme_color: string | null;
  chat_background: string | null;
  home_background?: string | null;
  avatar_url?: string | null;
  app_name?: string | null;
  app_scale?: string | null;
  header_color?: string | null;
  title_color?: string | null;
  title_font?: string | null;
  chat_name_font?: string | null;
  nicknames?: Record<string, string> | null;
};

type AppSettings = {
  id: number;
  app_name: string | null;
  app_icon?: string | null;
  header_color: string | null;
  title_color: string | null;
  title_font: string | null;
  chat_name_font: string | null;
};

type FamilyServer = {
  id: string;
  name: string;
  owner_id: string;
  invite_code: string;
  icon_url?: string | null;
  created_at?: string | null;
};

type FamilyServerMember = {
  family_id: string;
  user_id: string;
  role: string;
};

type Chat = {
  id: string;
  name: string;
  description?: string | null;
  is_family: boolean;
  owner_id: string | null;
  family_id?: string | null;
  invite_code: string | null;
  chat_color: string | null;
  chat_background: string | null;
  icon_url?: string | null;
  inbound_bubble_color?: string | null;
  inbound_text_color?: string | null;
  own_text_color?: string | null;
  message_input_bg?: string | null;
  message_input_text?: string | null;
  wallpaper_blur?: number | null;
  direct_key?: string | null;
  deleted_at?: string | null;
};

type ChatMember = {
  chat_id: string;
  user_id: string;
  role: string;
};

type Message = {
  id: number;
  chat_id: string;
  user_id: string | null;
  message: string;
  created_at: string;
  edited_at: string | null;
  deleted_at: string | null;
  deleted_by_name?: string | null;
  system_type?: string | null;
  attachment_url?: string | null;
  attachment_name?: string | null;
  attachment_type?: string | null;
};

type TypingUser = {
  user_id: string;
  display_name: string;
};

type MessageRead = {
  chat_id: string;
  user_id: string;
  read_at: string;
};

type FamilyDeletePoll = {
  id: string;
  family_id: string;
  created_by: string;
  created_at: string;
  expires_at: string;
  status: string;
};

type FamilyDeleteVote = {
  poll_id: string;
  user_id: string;
  vote: string;
  created_at: string;
};

type Story = {
  id: string;
  user_id: string;
  family_id: string;
  media_url: string;
  media_type: string;
  caption?: string | null;
  overlay_text?: string | null;
  overlay_color?: string | null;
  overlay_size?: string | null;
  overlay_position?: string | null;
  overlay_x?: number | null;
  overlay_y?: number | null;
  overlay_scale?: number | null;
  overlay_rotate?: number | null;
  filter_name?: string | null;
  created_at: string;
  expires_at: string;
};

type StoryView = {
  story_id: string;
  user_id: string;
  viewed_at: string;
};

type StoryTextItem = {
  id: string;
  text: string;
  color: string;
  x: number;
  y: number;
  scale: number;
  rotate: number;
  style?: string;
};

const APP_URL = "https://familyfeudapp.sbs";
const APP_NAME = "Family Feud";
const APP_ICON = "🦅";

