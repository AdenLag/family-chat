export default function Home() {
  const [screen, setScreen] = useState<Screen>("auth");
  const [settingsSection, setSettingsSection] = useState<
    | "main"
    | "profile"
    | "presets"
    | "home"
    | "chatDefault"
    | "display"
    | "appBar"
    | "permissions"
    | "admin"
    | "account"
  >("main");
  const [chatSettingsSection, setChatSettingsSection] = useState<
    "main" | "info" | "look" | "wallpaper" | "members" | "addPeople"
  >("main");
  const [isSignUp, setIsSignUp] = useState(true);
  const [authChecking, setAuthChecking] = useState(true);
  const [bootProgress, setBootProgress] = useState(8);
  const [bootMessage, setBootMessage] = useState("Opening Family Feud...");
  const [signOutConfirmOpen, setSignOutConfirmOpen] = useState(false);

  const [userId, setUserId] = useState("");
  const [profile, setProfile] = useState<Profile | null>(null);
  const [userEmail, setUserEmail] = useState("");
  const [appSettings, setAppSettings] = useState<AppSettings | null>(null);

  const [name, setName] = useState("");
  const [email, setEmail] = useState("");
  const [password, setPassword] = useState("");

  const [profiles, setProfiles] = useState<Profile[]>([]);
  const [familyServers, setFamilyServers] = useState<FamilyServer[]>([]);
  const [familyMembers, setFamilyMembers] = useState<FamilyServerMember[]>([]);
  const [currentFamily, setCurrentFamily] = useState<FamilyServer | null>(null);
  const [familyName, setFamilyName] = useState("");
  const [familyJoinCode, setFamilyJoinCode] = useState("");
  const [chats, setChats] = useState<Chat[]>([]);
  const [activeChat, setActiveChat] = useState<Chat | null>(null);
  const [chatMembers, setChatMembers] = useState<ChatMember[]>([]);
  const [allChatMembers, setAllChatMembers] = useState<ChatMember[]>([]);
  const [messages, setMessages] = useState<Message[]>([]);
  const [homeMessages, setHomeMessages] = useState<Message[]>([]);
  const [chatReads, setChatReads] = useState<Record<string, string>>({});
  const [activeReadReceipts, setActiveReadReceipts] = useState<MessageRead[]>(
    [],
  );
  const [message, setMessage] = useState("");
  const [typingUsers, setTypingUsers] = useState<TypingUser[]>([]);

  const [newChatMode, setNewChatMode] = useState<"direct" | "group">("direct");
  const [newChatName, setNewChatName] = useState("");
  const [newChatSearch, setNewChatSearch] = useState("");
  const [selectedPeople, setSelectedPeople] = useState<string[]>([]);

  const [settingsName, setSettingsName] = useState("");
  const [settingsAbout, setSettingsAbout] = useState("Ready to feud");
  const [settingsColor, setSettingsColor] = useState("patriot");
  const [settingsBackground, setSettingsBackground] = useState("patriot");
  const [settingsHomeBackground, setSettingsHomeBackground] =
    useState("patriot");
  const [settingsAvatar, setSettingsAvatar] = useState<string | null>(null);
  const [settingsAppName, setSettingsAppName] = useState("Family Feud");
  const [settingsAppIcon, setSettingsAppIcon] = useState<string | null>(null);
  const [settingsAppScale, setSettingsAppScale] = useState("normal");
  const [settingsHeaderColor, setSettingsHeaderColor] = useState(
    "rgba(255,255,255,.08)",
  );
  const [settingsTitleColor, setSettingsTitleColor] = useState("#ffffff");
  const [settingsTitleFont, setSettingsTitleFont] = useState("font-black");
  const [settingsChatNameFont, setSettingsChatNameFont] =
    useState("font-black");
  const [settingsHomeTextColor, setSettingsHomeTextColor] = useState("#ffffff");
  const [settingsHomePanelColor, setSettingsHomePanelColor] =
    useState("#020617");
  const [settingsHomeBlur, setSettingsHomeBlur] = useState(0);
  const [homeSearch, setHomeSearch] = useState("");
  const [homeSearchOpen, setHomeSearchOpen] = useState(false);
  const [nicknameUserId, setNicknameUserId] = useState("");
  const [nicknameValue, setNicknameValue] = useState("");

  const [chatName, setChatName] = useState("");
  const [chatDescription, setChatDescription] = useState("");
  const [chatIcon, setChatIcon] = useState<string | null>(null);
  const [chatColor, setChatColor] = useState("patriot");
  const [chatBackground, setChatBackground] = useState("patriot");
  const [customColor, setCustomColor] = useState("#2563eb");
  const [inboundBubbleColor, setInboundBubbleColor] = useState("#18181b");
  const [inboundTextColor, setInboundTextColor] = useState("#ffffff");
  const [ownTextColor, setOwnTextColor] = useState("#ffffff");
  const [messageInputBg, setMessageInputBg] = useState("#18181b");
  const [messageInputText, setMessageInputText] = useState("#ffffff");
  const [wallpaperBlur, setWallpaperBlur] = useState(0);
  const [pendingAttachments, setPendingAttachments] = useState<
    { url: string; name: string; type: string; progress: number }[]
  >([]);
  const [failedDraft, setFailedDraft] = useState<{
    text: string;
    attachments: {
      url: string;
      name: string;
      type: string;
      progress: number;
    }[];
  } | null>(null);
  const [sendingMessage, setSendingMessage] = useState(false);
  const [isRecordingVoice, setIsRecordingVoice] = useState(false);
  const [voiceNotice, setVoiceNotice] = useState("");
  const [previewAttachment, setPreviewAttachment] = useState<{
    url: string;
    name: string;
    type: string;
  } | null>(null);
  const [galleryItems, setGalleryItems] = useState<
    { url: string; name: string; type: string }[] | null
  >(null);
  const [directNickname, setDirectNickname] = useState("");

  const [editingId, setEditingId] = useState<number | null>(null);
  const [editingText, setEditingText] = useState("");
  const [openMenu, setOpenMenu] = useState<string | null>(null);
  const [familyMenuOpen, setFamilyMenuOpen] = useState(false);
  const [activeFamilyDeletePoll, setActiveFamilyDeletePoll] =
    useState<FamilyDeletePoll | null>(null);
  const [familyDeleteVotes, setFamilyDeleteVotes] = useState<
    FamilyDeleteVote[]
  >([]);
  const [familyDeleteBusy, setFamilyDeleteBusy] = useState(false);
  const [authError, setAuthError] = useState("");
  const [authBusy, setAuthBusy] = useState(false);
  const [formNotice, setFormNotice] = useState("");
  const [stories, setStories] = useState<Story[]>([]);
  const [storyViews, setStoryViews] = useState<StoryView[]>([]);
  const [storyCaption, setStoryCaption] = useState("");
  const [storyDraftUrl, setStoryDraftUrl] = useState("");
  const [storyDraftType, setStoryDraftType] = useState("image");
  const [storyOverlayText, setStoryOverlayText] = useState("");
  const [storyOverlayColor, setStoryOverlayColor] = useState("#ffffff");
  const [storyOverlaySize, setStoryOverlaySize] = useState("text-4xl");
  const [storyOverlayPosition, setStoryOverlayPosition] = useState("center");
  const [storyOverlayX, setStoryOverlayX] = useState(50);
  const [storyOverlayY, setStoryOverlayY] = useState(50);
  const [storyOverlayScale, setStoryOverlayScale] = useState(1);
  const [storyOverlayRotate, setStoryOverlayRotate] = useState(0);
  const [storyFilter, setStoryFilter] = useState("none");
  const [storyTool, setStoryTool] = useState<"text" | "style" | "move" | "filter" | "manage">("text");
  const [storyOptionsOpen, setStoryOptionsOpen] = useState(false);
  const [storyManageOpen, setStoryManageOpen] = useState(false);
  const [activeStoryIndex, setActiveStoryIndex] = useState<number | null>(null);
  const [storyTextItems, setStoryTextItems] = useState<StoryTextItem[]>([]);
  const [activeStoryTextId, setActiveStoryTextId] = useState<string | null>(null);
  const [storyPosting, setStoryPosting] = useState(false);

  const bottomRef = useRef<HTMLDivElement | null>(null);
  const storyGestureRef = useRef<{
    pointers: Map<number, { x: number; y: number }>;
    startDistance: number;
    startAngle: number;
    startScale: number;
    startRotate: number;
  }>({ pointers: new Map(), startDistance: 0, startAngle: 0, startScale: 1, startRotate: 0 });
  const typingTimer = useRef<NodeJS.Timeout | null>(null);
  const mediaRecorderRef = useRef<MediaRecorder | null>(null);
  const voiceChunksRef = useRef<Blob[]>([]);
  const voiceStartedAtRef = useRef(0);
  const voiceStreamRef = useRef<MediaStream | null>(null);
  const loadingAccountRef = useRef(false);
  const hasLoadedAccountRef = useRef(false);

  function getTheme(id?: string | null) {
    return themes.find((t) => t.id === id) || themes[0];
  }

  function bubbleClass(id?: string | null) {
    if (id?.startsWith("#")) return "";
    return `bg-gradient-to-r ${getTheme(id || profile?.theme_color || "patriot").cls}`;
  }

  function bubbleStyle(id?: string | null) {
    if (id?.startsWith("#")) return { background: id };
    return {};
  }

  function bgValue(value?: string | null) {
    if (!value) return backgrounds[0].css;
    if (value.startsWith("data:") || value.startsWith("http")) {
      return `linear-gradient(rgba(0,0,0,.68), rgba(0,0,0,.9)), url(${value})`;
    }
    const found = backgrounds.find((b) => b.id === value);
    return found ? found.css : value;
  }

  function pageBackground() {
    const bg =
      screen === "chat" || screen === "chatSettings"
        ? activeLook().chatBackground || profile?.chat_background || "patriot"
        : profile?.home_background || profile?.chat_background || "patriot";

    const value = bgValue(bg);

    if (value.includes("url(")) {
      return {
        backgroundImage: value,
        backgroundSize: "cover",
        backgroundPosition: "center",
        backgroundAttachment: "fixed",
      };
    }

    return { background: value, backgroundAttachment: "fixed" };
  }

  function card() {
    return "border border-white/10 bg-zinc-950/80 shadow-2xl shadow-black/40 backdrop-blur-xl";
  }

  function applyLookPreset(id: string) {
    const preset = lookPresets.find((x) => x.id === id);
    if (!preset) return;
    setSettingsHomeBackground(preset.homeBg);
    setSettingsBackground(preset.chatBg);
    setSettingsColor(preset.theme);
    setSettingsHomeTextColor(preset.homeText);
    setSettingsHomePanelColor(preset.homePanel);
    setSettingsHeaderColor(preset.header);
    setSettingsTitleColor(preset.title);
  }

  function applyChatLookPreset(id: string) {
    const preset = lookPresets.find((x) => x.id === id);
    if (!preset) return;
    setChatBackground(preset.chatBg);
    setChatColor(preset.theme);
    setInboundBubbleColor(preset.inbound);
    setInboundTextColor(preset.inboundText);
    setOwnTextColor(preset.inputText);
    setMessageInputBg(preset.inputBg);
    setMessageInputText(preset.inputText);
  }

  function localChatKey(chatId: string) {
    return `family-feud-chat-look-${userId}-${chatId}`;
  }

  function getLocalChatLook(chatId?: string | null) {
    if (!chatId || typeof window === "undefined") return null;
    try {
      return JSON.parse(localStorage.getItem(localChatKey(chatId)) || "null");
    } catch {
      return null;
    }
  }

  function saveLocalChatLook(chatId: string) {
    if (typeof window === "undefined") return;
    localStorage.setItem(
      localChatKey(chatId),
      JSON.stringify({
        chatColor,
        chatBackground,
        inboundBubbleColor,
        inboundTextColor,
        ownTextColor,
        messageInputBg,
        messageInputText,
        wallpaperBlur,
      }),
    );
  }

  function activeLook(): {
    chatColor: string;
    chatBackground: string;
    inboundBubbleColor: string;
    inboundTextColor: string;
    ownTextColor: string;
    messageInputBg: string;
    messageInputText: string;
    wallpaperBlur: number;
  } {
    const local = getLocalChatLook(activeChat?.id);
    return {
      chatColor:
        local?.chatColor || activeChat?.chat_color || chatColor || "patriot",
      chatBackground:
        local?.chatBackground ||
        activeChat?.chat_background ||
        chatBackground ||
        "patriot",
      inboundBubbleColor:
        local?.inboundBubbleColor ||
        activeChat?.inbound_bubble_color ||
        inboundBubbleColor ||
        "#18181b",
      inboundTextColor:
        local?.inboundTextColor ||
        activeChat?.inbound_text_color ||
        inboundTextColor ||
        "#ffffff",
      ownTextColor:
        local?.ownTextColor ||
        activeChat?.own_text_color ||
        ownTextColor ||
        "#ffffff",
      messageInputBg:
        local?.messageInputBg ||
        activeChat?.message_input_bg ||
        messageInputBg ||
        "#18181b",
      messageInputText:
        local?.messageInputText ||
        activeChat?.message_input_text ||
        messageInputText ||
        "#ffffff",
      wallpaperBlur: Number(
        local?.wallpaperBlur ??
          activeChat?.wallpaper_blur ??
          wallpaperBlur ??
          0,
      ),
    };
  }

  function isAppAdmin() {
    return false;
  }

  function randomInviteCode() {
    return (
      Math.random().toString(36).slice(2, 8).toUpperCase() +
      Math.random().toString(36).slice(2, 6).toUpperCase()
    );
  }

  function currentFamilyRole(id = userId) {
    if (!currentFamily) return "member";
    if (currentFamily.owner_id === id) return "owner";
    return (
      familyMembers.find(
        (m) => m.family_id === currentFamily.id && m.user_id === id,
      )?.role || "member"
    );
  }

  function isFamilyAdmin(id = userId) {
    const role = currentFamilyRole(id);
    return role === "owner" || role === "admin";
  }

  function appScaleValue() {
    const scale = profile?.app_scale || settingsAppScale || "normal";
    if (scale === "tiny") return 0.58;
    if (scale === "small") return 0.72;
    if (scale === "normal") return 0.86;
    if (scale === "large") return 1;
    if (scale === "huge") return 1.14;
    return 0.86;
  }

  function appScaleClass() {
    return "origin-top-left transform-gpu will-change-transform";
  }

  function scaledPageStyle(extra: CSSProperties = {}) {
    const scale = appScaleValue();
    return {
      ...pageBackground(),
      ...extra,
      width: `${100 / scale}%`,
      height: `${100 / scale}dvh`,
      transform: `scale(${scale})`,
      transformOrigin: "top left",
    } as CSSProperties;
  }

  function scaledChatStyle(extra: CSSProperties = {}) {
    const scale = appScaleValue();
    return {
      ...pageBackground(),
      ...extra,
      width: `${100 / scale}%`,
      height: `${100 / scale}dvh`,
      transform: `scale(${scale})`,
      transformOrigin: "top left",
    } as CSSProperties;
  }

  function appTitle() {
    return APP_NAME;
  }

  function appIcon() {
    return "";
  }

  function appHeaderStyle() {
    return { background: settingsHeaderColor || "rgba(255,255,255,.08)" };
  }

  function appTitleStyle() {
    return {
      color: appSettings?.title_color || settingsTitleColor || "#ffffff",
    };
  }

  function homeStyle() {
    return {
      color: profile?.home_text_color || settingsHomeTextColor || "#ffffff",
    };
  }

  function homePanelStyle() {
    const c = profile?.home_panel_color || settingsHomePanelColor || "#020617";
    return { background: c.startsWith("#") ? `${c}cc` : c };
  }

  function requestCameraPermission() {
    if (!navigator.mediaDevices?.getUserMedia) {
      alert("Camera permission is not available in this browser.");
      return;
    }
    navigator.mediaDevices
      .getUserMedia({ video: true })
      .then((stream) => {
        stream.getTracks().forEach((track) => track.stop());
        alert("Camera permission allowed.");
      })
      .catch((err) => alert(err?.message || "Camera permission was blocked."));
  }

  function requestPhotoPermission(inputId = "message-photo-input") {
    document.getElementById(inputId)?.click();
  }

  async function openCameraCapture() {
    try {
      if (navigator.mediaDevices?.getUserMedia) {
        const stream = await navigator.mediaDevices.getUserMedia({
          video: true,
        });
        stream.getTracks().forEach((track) => track.stop());
      }
    } catch {
      // The file input still opens so iOS/Android can request permission normally.
    }
    document.getElementById("message-camera-input")?.click();
  }

  async function requestMicrophonePermission() {
    if (!navigator.mediaDevices?.getUserMedia) {
      alert("Microphone permission is not available in this browser.");
      return;
    }

    try {
      const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      stream.getTracks().forEach((track) => track.stop());
      alert("Microphone permission allowed.");
    } catch (err: any) {
      alert(err?.message || "Microphone permission was blocked.");
    }
  }

  function stopVoiceTracks() {
    voiceStreamRef.current?.getTracks().forEach((track) => track.stop());
    voiceStreamRef.current = null;
  }

  async function startVoiceRecording(event?: React.PointerEvent<HTMLButtonElement>) {
    event?.preventDefault();
    if (isRecordingVoice || sendingMessage) return;

    if (!navigator.mediaDevices?.getUserMedia || typeof MediaRecorder === "undefined") {
      setVoiceNotice("Voice recording is not available in this browser.");
      return;
    }

    try {
      setVoiceNotice("Recording... release to attach.");
      const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      voiceStreamRef.current = stream;
      voiceChunksRef.current = [];
      voiceStartedAtRef.current = Date.now();

      const mimeType =
        MediaRecorder.isTypeSupported("audio/webm;codecs=opus")
          ? "audio/webm;codecs=opus"
          : MediaRecorder.isTypeSupported("audio/webm")
            ? "audio/webm"
            : MediaRecorder.isTypeSupported("audio/mp4")
              ? "audio/mp4"
              : "";

      const recorder = new MediaRecorder(stream, mimeType ? { mimeType } : undefined);
      mediaRecorderRef.current = recorder;

      recorder.ondataavailable = (recEvent) => {
        if (recEvent.data && recEvent.data.size > 0) {
          voiceChunksRef.current.push(recEvent.data);
        }
      };

      recorder.onstop = () => {
        const duration = Date.now() - voiceStartedAtRef.current;
        const chunks = [...voiceChunksRef.current];
        const type = chunks[0]?.type || mimeType || "audio/webm";
        stopVoiceTracks();
        setIsRecordingVoice(false);

        if (duration < 600 || !chunks.length) {
          setVoiceNotice("Hold the mic to record a voice message.");
          voiceChunksRef.current = [];
          return;
        }

        const blob = new Blob(chunks, { type });
        const reader = new FileReader();
        const extension = type.includes("mp4") ? "m4a" : "webm";
        const name = "voice-message-" + new Date().toISOString().replace(/[:.]/g, "-") + "." + extension;

        reader.onload = () => {
          setPendingAttachments((prev) =>
            [
              ...prev,
              {
                url: String(reader.result || ""),
                name,
                type,
                progress: 100,
              },
            ].slice(0, 18),
          );
          setVoiceNotice("Voice ready. Tap play to listen, then send.");
          voiceChunksRef.current = [];
        };

        reader.onerror = () => {
          setVoiceNotice("Voice message failed to load. Try again.");
          voiceChunksRef.current = [];
        };

        reader.readAsDataURL(blob);
      };

      recorder.start();
      setIsRecordingVoice(true);
    } catch (err: any) {
      stopVoiceTracks();
      setIsRecordingVoice(false);
      setVoiceNotice(err?.message || "Could not start microphone.");
    }
  }

  function stopVoiceRecording(event?: React.PointerEvent<HTMLButtonElement>) {
    event?.preventDefault();
    const recorder = mediaRecorderRef.current;
    if (!recorder || recorder.state === "inactive") {
      stopVoiceTracks();
      setIsRecordingVoice(false);
      return;
    }
    recorder.stop();
  }

  function cancelVoiceRecording() {
    const recorder = mediaRecorderRef.current;
    voiceChunksRef.current = [];
    if (recorder && recorder.state !== "inactive") {
      recorder.stop();
    }
    stopVoiceTracks();
    setIsRecordingVoice(false);
    setVoiceNotice("");
  }

  function initials(text?: string | null) {
    return (text || "?")
      .split(" ")
      .map((x) => x[0])
      .join("")
      .slice(0, 2)
      .toUpperCase();
  }

  function profileAvatar(id?: string | null) {
    if (!id) return null;
    return (
      profiles.find((p) => p.id === id)?.avatar_url ||
      (id === profile?.id ? profile?.avatar_url || null : null)
    );
  }

  function Avatar({
    id,
    name,
    size = "h-12 w-12",
    rounded = "rounded-2xl",
  }: {
    id?: string | null;
    name?: string | null;
    size?: string;
    rounded?: string;
  }) {
    const avatar = profileAvatar(id);

    if (avatar) {
      return (
        <div
          className={`${size} ${rounded} shrink-0 overflow-hidden border border-white/20 bg-black/40 shadow-lg shadow-black/40`}
        >
          <img
            src={avatar}
            alt={name || "Profile"}
            className="h-full w-full object-cover"
          />
        </div>
      );
    }

    return (
      <div
        className={`${size} ${rounded} flex shrink-0 items-center justify-center bg-gradient-to-br ${getTheme(profile?.theme_color || "patriot").cls} font-black text-white shadow-lg shadow-black/40`}
      >
        {initials(name)}
      </div>
    );
  }

  function profileName(id?: string | null) {
    if (!id) return "Someone";
    const nick = profile?.nicknames?.[id];
    if (nick) return nick;
    return profiles.find((p) => p.id === id)?.display_name || "Unknown";
  }

  function profileAbout(id?: string | null) {
    if (!id) return "Ready to feud";
    const found = profiles.find((p) => p.id === id) || (id === profile?.id ? profile : null);
    return found?.about?.trim() || "Ready to feud";
  }

  function tapFeedbackClass(extra = "") {
    return `${extra} transition duration-150 active:scale-[.97] active:brightness-125 active:blur-[.2px]`;
  }

  function isOwnMessage(msg: Message) {
    return String(msg.user_id || "") === String(userId || "");
  }

  function directKey(a: string, b: string) {
    return [a, b].sort().join("__");
  }

  function isMember(id: string) {
    return chatMembers.some((m) => m.user_id === id);
  }

  function otherDirectMemberId(chat: Chat) {
    const fromLoadedMembers = chatMembers.find(
      (m) => m.chat_id === chat.id && m.user_id !== userId,
    )?.user_id;
    if (fromLoadedMembers) return fromLoadedMembers;
    return (
      allChatMembers.find((m) => m.chat_id === chat.id && m.user_id !== userId)
        ?.user_id || null
    );
  }

  function chatTitle(chat?: Chat | null) {
    if (!chat) return "Chat";
    if (chat.direct_key) {
      const otherId = otherDirectMemberId(chat);
      return otherId ? profileName(otherId) : chat.name;
    }
    return chat.name;
  }

  function chatSubtitle(chat: Chat) {
    return chat.description?.trim() || "";
  }

  function formatHomeTime(value?: string | null) {
    if (!value) return "";
    const date = new Date(value);
    const now = new Date();
    const diff = now.getTime() - date.getTime();
    const day = 24 * 60 * 60 * 1000;
    if (diff < day)
      return date.toLocaleTimeString([], {
        hour: "2-digit",
        minute: "2-digit",
      });
    if (diff < 7 * day)
      return date.toLocaleDateString([], { weekday: "short" });
    const weeks = Math.floor(diff / (7 * day));
    if (weeks < 5) return `${weeks}w`;
    return date.toLocaleDateString([], { month: "short", day: "numeric" });
  }

  function formatChatTime(value?: string | null) {
    if (!value) return "";
    const date = new Date(value);
    const now = new Date();
    const diff = now.getTime() - date.getTime();
    const day = 24 * 60 * 60 * 1000;
    if (diff < day)
      return date.toLocaleTimeString([], {
        hour: "numeric",
        minute: "2-digit",
      });
    if (diff < 7 * day) {
      return `${date.toLocaleDateString([], { weekday: "short" })} ${date.toLocaleTimeString([], { hour: "numeric", minute: "2-digit" })}`;
    }
    return `${date.toLocaleDateString([], { month: "short", day: "numeric" })} ${date.toLocaleTimeString([], { hour: "numeric", minute: "2-digit" })}`;
  }

  function latestMessageFor(chatId: string) {
    return (
      homeMessages
        .filter((m) => m.chat_id === chatId && !m.deleted_at && !m.system_type)
        .sort(
          (a, b) =>
            new Date(b.created_at).getTime() - new Date(a.created_at).getTime(),
        )[0] || null
    );
  }

  function unreadCount(chatId: string) {
    const readAt = chatReads[chatId]
      ? new Date(chatReads[chatId]).getTime()
      : 0;
    return homeMessages.filter((m) => {
      if (m.chat_id !== chatId || m.deleted_at || m.system_type) return false;
      if (String(m.user_id || "") === String(userId || "")) return false;
      return new Date(m.created_at).getTime() > readAt;
    }).length;
  }

  function homePreview(chat: Chat) {
    const last = latestMessageFor(chat.id);
    if (last) {
      const sender =
        String(last.user_id || "") === String(userId || "")
          ? "You"
          : profileName(last.user_id);
      return `${sender}: ${last.message}`;
    }
    return chat.description?.trim() || "";
  }

  function messageAttachments(
    msg: Message,
  ): { url: string; name: string; type: string }[] {
    if (!msg.attachment_url) return [];
    if (msg.attachment_type === "gallery") {
      try {
        const parsed = JSON.parse(msg.attachment_url);
        return Array.isArray(parsed) ? parsed : [];
      } catch {
        return [];
      }
    }
    return [
      {
        url: msg.attachment_url,
        name: msg.attachment_name || "attachment",
        type: msg.attachment_type || "file",
      },
    ];
  }

  function visibleAttachmentGrid(
    items: { url: string; name: string; type: string }[],
  ) {
    const visible = items.slice(0, 6);
    const extra = Math.max(0, items.length - 6);
    return { visible, extra };
  }

  function messageWasRead(msg: Message) {
    if (!activeChat || !isOwnMessage(msg)) return false;
    return activeReadReceipts.some(
      (r) =>
        r.user_id !== userId &&
        new Date(r.read_at).getTime() >= new Date(msg.created_at).getTime(),
    );
  }

  function readByNames(msg: Message) {
    if (!isOwnMessage(msg)) return "";
    const names = activeReadReceipts
      .filter(
        (r) =>
          r.user_id !== userId &&
          new Date(r.read_at).getTime() >= new Date(msg.created_at).getTime(),
      )
      .map((r) => profileName(r.user_id));
    return names.length ? `Seen by ${names.join(", ")}` : "Not read yet";
  }

  function groupedNewChatProfiles() {
    const q = newChatSearch.trim().toLowerCase();
    const allowedIds = new Set(
      familyMembers
        .filter((m) => m.family_id === currentFamily?.id)
        .map((m) => m.user_id),
    );
    const rows = profiles
      .filter((p) => p.id !== userId && allowedIds.has(p.id))
      .filter(
        (p) =>
          !q ||
          profileName(p.id).toLowerCase().includes(q) ||
          p.display_name.toLowerCase().includes(q),
      )
      .sort((a, b) => profileName(a.id).localeCompare(profileName(b.id)));

    return rows.reduce<Record<string, Profile[]>>((acc, p) => {
      const letter = (profileName(p.id)[0] || "#").toUpperCase();
      const key = /[A-Z]/.test(letter) ? letter : "#";
      if (!acc[key]) acc[key] = [];
      acc[key].push(p);
      return acc;
    }, {});
  }




  function FixedBottomDock({ active }: { active: "home" | "stories" }) {
    return (
      <div className="pointer-events-none fixed inset-x-0 bottom-[calc(env(safe-area-inset-bottom)+.95rem)] z-[999] flex items-end justify-center px-4">
        {currentFamily && active === "home" && (
          <button
            onClick={() => setScreen("newChat")}
            className={`pointer-events-auto fixed bottom-[calc(env(safe-area-inset-bottom)+6.35rem)] right-5 z-[1000] flex h-16 w-16 translate-x-0 translate-y-0 transform-none items-center justify-center rounded-[1.35rem] text-3xl shadow-2xl shadow-black/60 will-change-auto ${bubbleClass(profile?.theme_color || "patriot")}`}
            style={bubbleStyle(profile?.theme_color)}
            title="New chat"
          >
            ✎
          </button>
        )}

        <div className="pointer-events-auto grid w-[min(92vw,420px)] translate-x-0 translate-y-0 transform-none grid-cols-2 overflow-hidden rounded-[1.6rem] border border-white/10 bg-zinc-950/92 p-1 shadow-2xl shadow-black/70 backdrop-blur-2xl backdrop-saturate-150 will-change-auto">
          <button
            onClick={() => setScreen("home")}
            className={`rounded-[1.25rem] py-3 text-sm font-black transition active:scale-[.98] ${active === "home" ? "bg-blue-600 text-white" : "text-white/65 hover:bg-white/10"}`}
          >
            💬 Chats
          </button>
          <button
            onClick={() => setScreen("stories")}
            className={`rounded-[1.25rem] py-3 text-sm font-black transition active:scale-[.98] ${active === "stories" ? "bg-blue-600 text-white" : "text-white/65 hover:bg-white/10"}`}
          >
            ⭕ Stories
          </button>
        </div>
      </div>
    );
  }

  function friendlyError(message?: string | null) {
    const text = (message || "Something went wrong. Try again.").toLowerCase();
    if (text.includes("invalid login") || text.includes("invalid credentials")) return "That email or password is not correct.";
    if (text.includes("email not confirmed")) return "Please confirm your email first, or turn off email confirmation in Supabase while testing.";
    if (text.includes("already registered") || text.includes("already exists")) return "That email already has an account. Try signing in instead.";
    if (text.includes("password")) return "Password must be at least 6 characters.";
    return message || "Something went wrong. Try again.";
  }

  function storiesByUser() {
    const rows = stories.filter((story) => new Date(story.expires_at).getTime() > Date.now());
    const grouped = new Map<string, Story[]>();
    rows.forEach((story) => {
      const next = grouped.get(story.user_id) || [];
      next.push(story);
      grouped.set(story.user_id, next.sort((a, b) => new Date(a.created_at).getTime() - new Date(b.created_at).getTime()));
    });
    return Array.from(grouped.entries())
      .map(([user_id, items]) => ({ user_id, items }))
      .sort((a, b) => {
        if (a.user_id === userId) return -1;
        if (b.user_id === userId) return 1;
        const aLast = new Date(a.items[a.items.length - 1]?.created_at || 0).getTime();
        const bLast = new Date(b.items[b.items.length - 1]?.created_at || 0).getTime();
        return bLast - aLast;
      });
  }

  function hasUnseenStory(userIdToCheck: string) {
    const userStories = stories.filter((story) => story.user_id === userIdToCheck);
    return userStories.some((story) => !storyViews.some((view) => view.story_id === story.id && view.user_id === userId));
  }

  async function loadStories(familyId = currentFamily?.id || "") {
    if (!familyId) {
      setStories([]);
      setStoryViews([]);
      return;
    }
    const now = new Date().toISOString();
    const [{ data: storyRows }, { data: viewRows }] = await Promise.all([
      supabase.from("stories").select("*").eq("family_id", familyId).gt("expires_at", now).order("created_at", { ascending: true }),
      supabase.from("story_views").select("*").eq("user_id", userId),
    ]);
    if (storyRows) setStories(storyRows as Story[]);
    if (viewRows) setStoryViews(viewRows as StoryView[]);
  }

  async function createStoryFromFile(file: File) {
    if (!currentFamily || !userId) return;
    setFormNotice("Loading story editor...");
    const reader = new FileReader();
    reader.onload = () => {
      setStoryDraftUrl(String(reader.result || ""));
      setStoryDraftType(file.type.startsWith("video") ? "video" : "image");
      setStoryCaption("");
      setStoryOverlayText("");
      setStoryOverlayColor("#ffffff");
      setStoryOverlaySize("text-4xl");
      setStoryOverlayPosition("center");
      setStoryOverlayX(50);
      setStoryOverlayY(50);
      setStoryOverlayScale(1);
      setStoryOverlayRotate(0);
      setStoryFilter("none");
      setStoryTool("text");
      setStoryOptionsOpen(false);
      setStoryTextItems([]);
      setActiveStoryTextId(null);
      setStoryPosting(false);
      setFormNotice("");
    };
    reader.onerror = () => setFormNotice("That story could not be loaded. Try another photo or video.");
    reader.readAsDataURL(file);
  }

  function clearStoryDraft() {
    setStoryDraftUrl("");
    setStoryDraftType("image");
    setStoryCaption("");
    setStoryOverlayText("");
    setStoryOverlayColor("#ffffff");
    setStoryOverlaySize("text-4xl");
    setStoryOverlayPosition("center");
    setStoryFilter("none");
    setStoryOptionsOpen(false);
    setStoryTextItems([]);
    setActiveStoryTextId(null);
    setFormNotice("");
  }

  function storyFilterClass(name?: string | null) {
    if (name === "warm") return "sepia saturate-150 contrast-110";
    if (name === "cool") return "saturate-150 hue-rotate-15 contrast-110";
    if (name === "cinema") return "contrast-125 brightness-90 saturate-125";
    if (name === "mono") return "grayscale contrast-125";
    if (name === "dream") return "brightness-110 saturate-150 blur-[.2px]";
    return "";
  }

  function storyOverlayPositionClass(position?: string | null) {
    if (position === "top") return "top-10 left-5 right-5 items-center justify-center text-center";
    if (position === "bottom") return "bottom-16 left-5 right-5 items-center justify-center text-center";
    if (position === "left") return "left-5 top-1/2 -translate-y-1/2 items-start justify-start text-left";
    if (position === "right") return "right-5 top-1/2 -translate-y-1/2 items-end justify-end text-right";
    return "inset-0 items-center justify-center text-center";
  }

  function storyOverlayTransformStyle(story?: Partial<Story> | null): CSSProperties {
    const x = Number(story?.overlay_x ?? storyOverlayX ?? 50);
    const y = Number(story?.overlay_y ?? storyOverlayY ?? 50);
    const scale = Number(story?.overlay_scale ?? storyOverlayScale ?? 1);
    const rotate = Number(story?.overlay_rotate ?? storyOverlayRotate ?? 0);
    return {
      left: `${x}%`,
      top: `${y}%`,
      transform: `translate(-50%, -50%) scale(${scale}) rotate(${rotate}deg)`,
      touchAction: "none",
    };
  }

  function dragStoryOverlay(event: React.PointerEvent<HTMLDivElement>) {
    const stage = event.currentTarget.parentElement;
    if (!stage) return;

    const gesture = storyGestureRef.current;
    gesture.pointers.set(event.pointerId, { x: event.clientX, y: event.clientY });
    event.currentTarget.setPointerCapture?.(event.pointerId);

    const pointerValues = Array.from(gesture.pointers.values());
    if (pointerValues.length >= 2) {
      const [a, b] = pointerValues;
      gesture.startDistance = Math.hypot(b.x - a.x, b.y - a.y) || 1;
      gesture.startAngle = Math.atan2(b.y - a.y, b.x - a.x) * 180 / Math.PI;
      gesture.startScale = storyOverlayScale;
      gesture.startRotate = storyOverlayRotate;
    }

    const move = (moveEvent: PointerEvent) => {
      if (!gesture.pointers.has(moveEvent.pointerId)) return;
      gesture.pointers.set(moveEvent.pointerId, { x: moveEvent.clientX, y: moveEvent.clientY });
      const values = Array.from(gesture.pointers.values());

      if (values.length >= 2) {
        const [a, b] = values;
        const distance = Math.hypot(b.x - a.x, b.y - a.y) || 1;
        const angle = Math.atan2(b.y - a.y, b.x - a.x) * 180 / Math.PI;
        const nextScale = Math.max(0.45, Math.min(3.2, gesture.startScale * (distance / Math.max(1, gesture.startDistance))));
        const nextRotate = Math.max(-75, Math.min(75, gesture.startRotate + (angle - gesture.startAngle)));
        setStoryOverlayScale(Number(nextScale.toFixed(2)));
        setStoryOverlayRotate(Number(nextRotate.toFixed(1)));

        const rect = stage.getBoundingClientRect();
        const centerX = (a.x + b.x) / 2;
        const centerY = (a.y + b.y) / 2;
        setStoryOverlayX(Math.max(6, Math.min(94, ((centerX - rect.left) / rect.width) * 100)));
        setStoryOverlayY(Math.max(6, Math.min(94, ((centerY - rect.top) / rect.height) * 100)));
        setStoryOverlayPosition("custom");
        return;
      }

      const rect = stage.getBoundingClientRect();
      setStoryOverlayX(Math.max(6, Math.min(94, ((moveEvent.clientX - rect.left) / rect.width) * 100)));
      setStoryOverlayY(Math.max(6, Math.min(94, ((moveEvent.clientY - rect.top) / rect.height) * 100)));
      setStoryOverlayPosition("custom");
    };

    const up = (upEvent: PointerEvent) => {
      gesture.pointers.delete(upEvent.pointerId);
      if (!gesture.pointers.size) {
        window.removeEventListener("pointermove", move);
        window.removeEventListener("pointerup", up);
        window.removeEventListener("pointercancel", up);
      }
    };

    window.addEventListener("pointermove", move);
    window.addEventListener("pointerup", up);
    window.addEventListener("pointercancel", up);
  }

  function serializeStoryTextItems() {
    const clean = storyTextItems
      .map((item) => ({ ...item, text: item.text.trim() }))
      .filter((item) => item.text.length > 0);
    if (!clean.length && storyOverlayText.trim()) {
      clean.push({
        id: "legacy",
        text: storyOverlayText.trim(),
        color: storyOverlayColor,
        x: storyOverlayX,
        y: storyOverlayY,
        scale: storyOverlayScale,
        rotate: storyOverlayRotate,
      });
    }
    return clean;
  }

  function readStoryTextItems(story: Partial<Story> | null | undefined): StoryTextItem[] {
    const raw = story?.overlay_text || "";
    if (!raw) return [];
    try {
      const parsed = JSON.parse(raw);
      if (Array.isArray(parsed)) {
        return parsed
          .filter((item) => item && typeof item.text === "string")
          .map((item, index) => ({
            id: String(item.id || index),
            text: String(item.text || ""),
            color: String(item.color || story?.overlay_color || "#ffffff"),
            x: Number(item.x ?? story?.overlay_x ?? 50),
            y: Number(item.y ?? story?.overlay_y ?? 50),
            scale: Number(item.scale ?? story?.overlay_scale ?? 1),
            rotate: Number(item.rotate ?? story?.overlay_rotate ?? 0),
            style: String(item.style || "classic"),
          }));
      }
    } catch {
      // old single-text stories still render below
    }
    return [{
      id: "legacy",
      text: raw,
      color: story?.overlay_color || "#ffffff",
      x: Number(story?.overlay_x ?? 50),
      y: Number(story?.overlay_y ?? 50),
      scale: Number(story?.overlay_scale ?? 1),
      rotate: Number(story?.overlay_rotate ?? 0),
      style: "classic",
    }];
  }

  function storyTextItemStyle(item: Partial<StoryTextItem>): CSSProperties {
    const x = Number(item.x ?? 50);
    const y = Number(item.y ?? 50);
    const scale = Number(item.scale ?? 1);
    const rotate = Number(item.rotate ?? 0);
    return {
      left: `${x}%`,
      top: `${y}%`,
      transform: `translate(-50%, -50%) scale(${scale}) rotate(${rotate}deg)`,
      touchAction: "none",
    };
  }

  function storyTextDisplayClass(style?: string) {
    if (style === "serif") return "font-serif tracking-wide";
    if (style === "mono") return "font-mono uppercase tracking-[.18em]";
    if (style === "soft") return "font-black italic tracking-wide";
    if (style === "bubble") return "font-black";
    if (style === "outline") return "font-black";
    if (style === "glow") return "font-black tracking-wide";
    return "font-black";
  }

  function storyTextDisplayStyle(item: Partial<StoryTextItem>): CSSProperties {
    const color = item.color || "#ffffff";
    const style = item.style || "classic";
    if (style === "outline") {
      return { color, WebkitTextStroke: "1.5px rgba(0,0,0,.85)", textShadow: "0 4px 16px rgba(0,0,0,.75)" } as CSSProperties;
    }
    if (style === "glow") {
      return { color, textShadow: "0 0 10px " + color + ", 0 4px 18px rgba(0,0,0,.9)" } as CSSProperties;
    }
    if (style === "bubble") {
      return { color, background: "rgba(0,0,0,.38)", borderRadius: "1.25rem", backdropFilter: "blur(10px)", boxShadow: "0 16px 40px rgba(0,0,0,.35)" } as CSSProperties;
    }
    return { color, textShadow: "0 4px 18px rgba(0,0,0,.9)" } as CSSProperties;
  }

  function selectStoryTextStyle(style: string) {
    if (!activeStoryTextId) return;
    updateStoryTextItem(activeStoryTextId, { style });
  }

  function startStoryStageTextGesture(event: React.PointerEvent<HTMLDivElement>) {
    const target = event.target as HTMLElement;
    if (target.closest("[data-story-ui='true']") || target.closest("[data-story-text-item='true']")) return;

    setStoryOptionsOpen(false);

    if (!activeStoryTextId) {
      setActiveStoryTextId(null);
      return;
    }

    event.preventDefault();
    const stage = event.currentTarget;
    const gesture = storyGestureRef.current;
    gesture.pointers.set(event.pointerId, { x: event.clientX, y: event.clientY });
    stage.setPointerCapture?.(event.pointerId);

    const current = storyTextItems.find((item) => item.id === activeStoryTextId);
    if (!current) return;

    const pointerValues = Array.from(gesture.pointers.values());
    if (pointerValues.length >= 2) {
      const [a, b] = pointerValues;
      gesture.startDistance = Math.hypot(b.x - a.x, b.y - a.y) || 1;
      gesture.startAngle = Math.atan2(b.y - a.y, b.x - a.x) * 180 / Math.PI;
      gesture.startScale = current.scale;
      gesture.startRotate = current.rotate;
    }

    const move = (moveEvent: PointerEvent) => {
      if (!gesture.pointers.has(moveEvent.pointerId) || !activeStoryTextId) return;
      moveEvent.preventDefault();
      gesture.pointers.set(moveEvent.pointerId, { x: moveEvent.clientX, y: moveEvent.clientY });
      const values = Array.from(gesture.pointers.values());
      if (values.length < 2) return;

      const [a, b] = values;
      const rect = stage.getBoundingClientRect();
      const distance = Math.hypot(b.x - a.x, b.y - a.y) || 1;
      const angle = Math.atan2(b.y - a.y, b.x - a.x) * 180 / Math.PI;
      const centerX = (a.x + b.x) / 2;
      const centerY = (a.y + b.y) / 2;

      updateStoryTextItem(activeStoryTextId, {
        x: Math.max(4, Math.min(96, ((centerX - rect.left) / rect.width) * 100)),
        y: Math.max(4, Math.min(96, ((centerY - rect.top) / rect.height) * 100)),
        scale: Number(Math.max(0.35, Math.min(4.8, gesture.startScale * (distance / Math.max(1, gesture.startDistance)))).toFixed(2)),
        rotate: Number(Math.max(-120, Math.min(120, gesture.startRotate + (angle - gesture.startAngle))).toFixed(1)),
      });
    };

    const up = (upEvent: PointerEvent) => {
      gesture.pointers.delete(upEvent.pointerId);
      if (!gesture.pointers.size) {
        window.removeEventListener("pointermove", move);
        window.removeEventListener("pointerup", up);
        window.removeEventListener("pointercancel", up);
      }
    };

    window.addEventListener("pointermove", move, { passive: false });
    window.addEventListener("pointerup", up);
    window.addEventListener("pointercancel", up);
  }

  function addStoryTextItem() {
    const id = `text-${Date.now()}-${Math.random().toString(36).slice(2)}`;
    setStoryTextItems((prev) => [...prev, { id, text: "", color: storyOverlayColor, x: 50, y: 45, scale: 1.2, rotate: 0, style: "classic" }]);
    setActiveStoryTextId(id);
    setStoryTool("text");
    setStoryOptionsOpen(false);
  }

  function removeActiveStoryTextItem() {
    if (!activeStoryTextId) return;
    setStoryTextItems((prev) => prev.filter((item) => item.id !== activeStoryTextId));
    setActiveStoryTextId(null);
    setStoryOptionsOpen(false);
  }

  function updateStoryTextItem(id: string, patch: Partial<StoryTextItem>) {
    setStoryTextItems((prev) => prev.map((item) => item.id === id ? { ...item, ...patch } : item));
  }

  function dragStoryTextItem(event: React.PointerEvent<HTMLDivElement>, id: string) {
    event.preventDefault();
    event.stopPropagation();
    const stage = event.currentTarget.parentElement;
    if (!stage) return;
    setActiveStoryTextId(id);
    const gesture = storyGestureRef.current;
    gesture.pointers.set(event.pointerId, { x: event.clientX, y: event.clientY });
    event.currentTarget.setPointerCapture?.(event.pointerId);

    const current = storyTextItems.find((item) => item.id === id);
    if (!current) return;

    const pointerValues = Array.from(gesture.pointers.values());
    if (pointerValues.length >= 2) {
      const [a, b] = pointerValues;
      gesture.startDistance = Math.hypot(b.x - a.x, b.y - a.y) || 1;
      gesture.startAngle = Math.atan2(b.y - a.y, b.x - a.x) * 180 / Math.PI;
      gesture.startScale = current.scale;
      gesture.startRotate = current.rotate;
    }

    const move = (moveEvent: PointerEvent) => {
      if (!gesture.pointers.has(moveEvent.pointerId)) return;
      moveEvent.preventDefault();
      gesture.pointers.set(moveEvent.pointerId, { x: moveEvent.clientX, y: moveEvent.clientY });
      const values = Array.from(gesture.pointers.values());
      const rect = stage.getBoundingClientRect();

      if (values.length >= 2) {
        const [a, b] = values;
        const distance = Math.hypot(b.x - a.x, b.y - a.y) || 1;
        const angle = Math.atan2(b.y - a.y, b.x - a.x) * 180 / Math.PI;
        const centerX = (a.x + b.x) / 2;
        const centerY = (a.y + b.y) / 2;
        updateStoryTextItem(id, {
          x: Math.max(6, Math.min(94, ((centerX - rect.left) / rect.width) * 100)),
          y: Math.max(6, Math.min(94, ((centerY - rect.top) / rect.height) * 100)),
          scale: Number(Math.max(0.45, Math.min(3.8, gesture.startScale * (distance / Math.max(1, gesture.startDistance)))).toFixed(2)),
          rotate: Number(Math.max(-85, Math.min(85, gesture.startRotate + (angle - gesture.startAngle))).toFixed(1)),
        });
        return;
      }

      updateStoryTextItem(id, {
        x: Math.max(6, Math.min(94, ((moveEvent.clientX - rect.left) / rect.width) * 100)),
        y: Math.max(6, Math.min(94, ((moveEvent.clientY - rect.top) / rect.height) * 100)),
      });
    };

    const up = (upEvent: PointerEvent) => {
      gesture.pointers.delete(upEvent.pointerId);
      if (!gesture.pointers.size) {
        window.removeEventListener("pointermove", move);
        window.removeEventListener("pointerup", up);
        window.removeEventListener("pointercancel", up);
      }
    };

    window.addEventListener("pointermove", move, { passive: false });
    window.addEventListener("pointerup", up);
    window.addEventListener("pointercancel", up);
  }

  async function publishStory() {
    if (!currentFamily || !userId || !storyDraftUrl) return setFormNotice("Choose a photo or video first.");

    const textItems = serializeStoryTextItems();
    const draftUrl = storyDraftUrl;
    const draftType = storyDraftType;
    const caption = storyCaption.trim() || null;
    const overlayText = textItems.length ? JSON.stringify(textItems) : null;
    const firstText = textItems[0] || null;

    setStoryPosting(true);
    setFormNotice("Posting story...");
    clearStoryDraft();
    setScreen("stories");

    const { error } = await supabase.from("stories").insert({
      family_id: currentFamily.id,
      user_id: userId,
      media_url: draftUrl,
      media_type: draftType,
      caption,
      overlay_text: overlayText,
      overlay_color: firstText?.color || storyOverlayColor,
      overlay_size: storyOverlaySize,
      overlay_position: "custom",
      overlay_x: firstText?.x ?? storyOverlayX,
      overlay_y: firstText?.y ?? storyOverlayY,
      overlay_scale: firstText?.scale ?? storyOverlayScale,
      overlay_rotate: firstText?.rotate ?? storyOverlayRotate,
      filter_name: storyFilter,
      expires_at: new Date(Date.now() + 24 * 60 * 60 * 1000).toISOString(),
    });

    if (error) {
      setStoryPosting(false);
      setFormNotice(friendlyError(error.message));
      return;
    }

    setStoryPosting(false);
    setFormNotice("Story posted. It will disappear 24 hours after posting.");
    await loadStories(currentFamily.id);
  }

  async function deleteStory(storyId: string) {
    const ok = window.confirm("Delete this story now?");
    if (!ok) return;
    const { error } = await supabase.from("stories").delete().eq("id", storyId).eq("user_id", userId);
    if (error) return setFormNotice(friendlyError(error.message));
    setFormNotice("Story deleted.");
    if (currentFamily) await loadStories(currentFamily.id);
  }

  async function editStoryCaption(story: Story) {
    const next = window.prompt("Edit story caption", story.caption || "");
    if (next === null) return;
    const { error } = await supabase.from("stories").update({ caption: next.trim() || null }).eq("id", story.id).eq("user_id", userId);
    if (error) return setFormNotice(friendlyError(error.message));
    setFormNotice("Story updated.");
    if (currentFamily) await loadStories(currentFamily.id);
  }

  async function openStoryIndex(index: number) {
    const flat = storiesByUser().flatMap((group) => group.items);
    const story = flat[index];
    if (!story) return;
    setActiveStoryIndex(index);
    await supabase.from("story_views").upsert({ story_id: story.id, user_id: userId });
    await loadStories(story.family_id);
  }

  function roleOf(id: string) {
    return chatMembers.find((m) => m.user_id === id)?.role || "member";
  }

  function isOwner(id = userId) {
    return activeChat?.owner_id === id || roleOf(id) === "owner";
  }

  function isAdmin(id = userId) {
    return isOwner(id) || roleOf(id) === "admin";
  }

  async function signInWithGoogle() {
    setAuthError("");
    setAuthBusy(true);
    const { error } = await supabase.auth.signInWithOAuth({
      provider: "google",
      options: { redirectTo: APP_URL },
    });
    if (error) setAuthError(friendlyError(error.message));
    setAuthBusy(false);
  }

  async function signUp() {
    setAuthError("");
    if (!name.trim()) return setAuthError("Add your display name first.");
    if (!email.trim()) return setAuthError("Add your email first.");
    if (!password.trim()) return setAuthError("Add your password first.");
    if (password.length < 6) return setAuthError("Password must be at least 6 characters.");
    setAuthBusy(true);
    const { data, error } = await supabase.auth.signUp({ email, password });
    if (error) {
      setAuthError(friendlyError(error.message));
      setAuthBusy(false);
      return;
    }
    if (data.user) {
      await ensureProfile(data.user.id, name.trim());
      await loadAccount(data.user.id, true);
    }
    setAuthChecking(false);
    setAuthBusy(false);
  }

  async function signIn() {
    setAuthError("");
    if (!email.trim()) return setAuthError("Add your email first.");
    if (!password.trim()) return setAuthError("Add your password first.");
    setAuthBusy(true);
    const { data, error } = await supabase.auth.signInWithPassword({
      email,
      password,
    });
    if (error) {
      setAuthError(friendlyError(error.message));
      setAuthBusy(false);
      return;
    }
    if (data.user) await loadAccount(data.user.id, true);
    setAuthChecking(false);
    setAuthBusy(false);
  }

  function signOut() {
    setSignOutConfirmOpen(true);
  }

  async function confirmSignOut() {
    setSignOutConfirmOpen(false);
    await supabase.auth.signOut();
    hasLoadedAccountRef.current = false;
    setUserId("");
    setProfile(null);
    setChats([]);
    setMessages([]);
    setScreen("auth");
  }

  async function ensureProfile(id: string, fallbackName?: string) {
    const { data: authData } = await supabase.auth.getUser();
    const authEmail = authData.user?.email || null;
    const { data: existing } = await supabase
      .from("profiles")
      .select("*")
      .eq("id", id)
      .maybeSingle();
    if (existing) {
      if (authEmail && existing.email !== authEmail) {
        const { data: updated } = await supabase
          .from("profiles")
          .update({ email: authEmail })
          .eq("id", id)
          .select("*")
          .single();
        if (updated) return updated as Profile;
      }
      return existing as Profile;
    }
    const displayName =
      fallbackName ||
      authData.user?.user_metadata?.full_name ||
      authData.user?.email?.split("@")[0] ||
      "Family Member";

    const { data } = await supabase
      .from("profiles")
      .insert({
        id,
        email: authEmail,
        display_name: displayName,
        theme_color: "patriot",
        chat_background: "patriot",
        home_background: "patriot",
        avatar_url: authData.user?.user_metadata?.avatar_url || null,
        app_name: "Family Feud",
        app_scale: "normal",
        header_color: "rgba(255,255,255,.08)",
        title_color: "#ffffff",
        title_font: "font-black",
        chat_name_font: "font-black",
        home_text_color: "#ffffff",
        home_panel_color: "#020617",
        about: "Ready to feud",
      })
      .select("*")
      .single();

    return data as Profile;
  }

  async function loadFamilyServers(id = userId) {
    if (!id)
      return {
        servers: [] as FamilyServer[],
        members: [] as FamilyServerMember[],
      };

    const { data: memberships } = await supabase
      .from("family_members")
      .select("*")
      .eq("user_id", id);
    const myMemberships = (memberships || []) as FamilyServerMember[];

    const ids = myMemberships.map((m) => m.family_id);
    if (!ids.length) {
      setFamilyMembers([]);
      setFamilyServers([]);
      setCurrentFamily(null);
      return { servers: [] as FamilyServer[], members: [] as FamilyServerMember[] };
    }

    const { data: allMemberRows } = await supabase
      .from("family_members")
      .select("*")
      .in("family_id", ids);
    const members = (allMemberRows || myMemberships) as FamilyServerMember[];
    setFamilyMembers(members);

    const { data: servers } = await supabase
      .from("family_servers")
      .select("*")
      .in("id", ids)
      .order("created_at", { ascending: true });
    const rows = (servers || []) as FamilyServer[];
    setFamilyServers(rows);
    const saved =
      typeof window !== "undefined"
        ? localStorage.getItem(`family-feud-current-family-${id}`)
        : null;
    const next = rows.find((x) => x.id === saved) || rows[0] || null;
    setCurrentFamily(next);
    return { servers: rows, members };
  }

  async function createFamilyServer() {
    if (!familyName.trim() || !userId)
      return alert("Name your family chat first.");

    const invite_code = randomInviteCode();
    const { data: server, error } = await supabase
      .from("family_servers")
      .insert({ name: familyName.trim(), owner_id: userId, invite_code })
      .select("*")
      .single();

    if (error || !server)
      return alert(error?.message || "Could not create family chat.");

    await supabase
      .from("family_members")
      .insert({ family_id: server.id, user_id: userId, role: "owner" });

    const { data: familyChat, error: chatError } = await supabase
      .from("chats")
      .insert({
        name: server.name,
        family_id: server.id,
        owner_id: userId,
        is_family: true,
        invite_code,
        chat_color: "patriot",
        chat_background: "patriot",
      })
      .select("*")
      .single();

    if (chatError || !familyChat)
      return alert(
        chatError?.message ||
          "Family was created, but the main chat could not be created.",
      );

    await supabase
      .from("chat_members")
      .insert({ chat_id: familyChat.id, user_id: userId, role: "owner" });
    setFamilyName("");
    setCurrentFamily(server as FamilyServer);
    if (typeof window !== "undefined")
      localStorage.setItem(`family-feud-current-family-${userId}`, server.id);
    await loadFamilyServers(userId);
    await loadChats(userId, server.id);
    await loadActiveFamilyDeletePoll(server.id);
    await loadStories(server.id);
    setScreen("home");
  }

  async function joinFamilyServer() {
    const code = familyJoinCode.trim().toUpperCase();
    if (!code || !userId) return alert("Enter the family invite code.");
    await joinInvite(code, userId);
    setFamilyJoinCode("");
  }

  async function loadAccount(id: string, goHome = false) {
    if (loadingAccountRef.current) return;
    loadingAccountRef.current = true;

    try {
      setUserId(id);
      const { data: authNow } = await supabase.auth.getUser();
      setUserEmail(authNow.user?.email || "");
      const row = await ensureProfile(id);

      setProfile(row);
      setSettingsName(row.display_name);
      setSettingsAbout(row.about?.trim() || "Ready to feud");
      setSettingsColor(row.theme_color || "patriot");
      setSettingsBackground(row.chat_background || "patriot");
      setSettingsHomeBackground(row.home_background || "patriot");
      setSettingsAvatar(row.avatar_url || null);
      setSettingsAppScale(row.app_scale || "normal");
      setSettingsHomeTextColor(row.home_text_color || "#ffffff");
      setSettingsHomePanelColor(row.home_panel_color || "#020617");
      setSettingsHomeBlur(Number(row.home_wallpaper_blur || 0));

      const params = new URLSearchParams(window.location.search);
      const invite = params.get("invite") || params.get("family");
      if (invite) await joinInvite(invite, id, false);

      await loadProfiles();
      const { servers } = await loadFamilyServers(id);
      const activeFamily =
        servers.find(
          (x) =>
            x.id ===
            (typeof window !== "undefined"
              ? localStorage.getItem(`family-feud-current-family-${id}`)
              : null),
        ) ||
        servers[0] ||
        null;

      if (!activeFamily) {
        setChats([]);
        setCurrentFamily(null);
        hasLoadedAccountRef.current = true;
        setScreen("home");
        return;
      }

      setCurrentFamily(activeFamily);
      await loadChats(id, activeFamily.id);
      await loadActiveFamilyDeletePoll(activeFamily.id);
      await loadStories(activeFamily.id);
      hasLoadedAccountRef.current = true;
      if (goHome || screen === "auth" || screen === "familyGate")
        setScreen("home");
    } finally {
      loadingAccountRef.current = false;
    }
  }

  async function loadProfiles() {
    const { data } = await supabase
      .from("profiles")
      .select("*")
      .order("created_at", { ascending: true });
    if (data) setProfiles(data as Profile[]);
  }

  async function refreshFamilyPeople() {
    await loadProfiles();
    if (userId) await loadFamilyServers(userId);
    if (activeChat?.id) await loadChatMembers(activeChat.id);
  }

  async function loadChats(id = userId, familyId = currentFamily?.id || "") {
    if (!id || !familyId) {
      setChats([]);
      return;
    }

    const { data: memberships } = await supabase
      .from("chat_members")
      .select("chat_id,user_id,role")
      .eq("user_id", id);
    const ids = memberships?.map((m) => m.chat_id) || [];

    if (!ids.length) {
      setChats([]);
      return;
    }

    const { data } = await supabase
      .from("chats")
      .select("*")
      .in("id", ids)
      .eq("family_id", familyId)
      .is("deleted_at", null)
      .order("is_family", { ascending: false })
      .order("created_at", { ascending: true });

    if (data) {
      setChats(data as Chat[]);
      const chatIds = (data as Chat[]).map((c) => c.id);
      if (!chatIds.length) return;
      const { data: memberRows } = await supabase
        .from("chat_members")
        .select("*")
        .in("chat_id", chatIds);
      if (memberRows) setAllChatMembers(memberRows as ChatMember[]);

      const { data: recentMessages } = await supabase
        .from("messages")
        .select("*")
        .in("chat_id", chatIds)
        .order("created_at", { ascending: false })
        .limit(500);
      if (recentMessages) setHomeMessages(recentMessages as Message[]);

      const { data: reads } = await supabase
        .from("message_reads")
        .select("*")
        .eq("user_id", id)
        .in("chat_id", chatIds);
      if (reads) {
        const next: Record<string, string> = {};
        (reads as MessageRead[]).forEach((r) => {
          next[r.chat_id] = r.read_at;
        });
        setChatReads(next);
      }
    }
  }

  async function loadChatMembers(chatId: string) {
    const { data } = await supabase
      .from("chat_members")
      .select("*")
      .eq("chat_id", chatId);
    if (data) setChatMembers(data as ChatMember[]);
  }

  async function joinInvite(code: string, id = userId, goHome = true) {
    const cleanCode = code.trim().toUpperCase();
    if (!cleanCode || !id) return;

    const { data: family } = await supabase
      .from("family_servers")
      .select("*")
      .eq("invite_code", cleanCode)
      .maybeSingle();
    if (family) {
      await supabase
        .from("family_members")
        .upsert({ family_id: family.id, user_id: id, role: "member" });

      const { data: familyChats } = await supabase
        .from("chats")
        .select("id")
        .eq("family_id", family.id)
        .eq("is_family", true)
        .is("deleted_at", null)
        .limit(1);
      const mainChatId = familyChats?.[0]?.id;
      if (mainChatId)
        await supabase
          .from("chat_members")
          .upsert({ chat_id: mainChatId, user_id: id, role: "member" });

      setCurrentFamily(family as FamilyServer);
      if (typeof window !== "undefined") {
        localStorage.setItem(`family-feud-current-family-${id}`, family.id);
        window.history.replaceState({}, "", window.location.pathname);
      }
      await loadFamilyServers(id);
      await loadChats(id, family.id);
      if (goHome) setScreen("home");
      return;
    }

    const { data: chat } = await supabase
      .from("chats")
      .select("*")
      .eq("invite_code", cleanCode)
      .maybeSingle();
    if (!chat) return alert("That invite code was not found.");

    if (chat.family_id) {
      await supabase
        .from("family_members")
        .upsert({ family_id: chat.family_id, user_id: id, role: "member" });
    }

    await supabase.from("chat_members").upsert({
      chat_id: chat.id,
      user_id: id,
      role: "member",
    });

    if (typeof window !== "undefined")
      window.history.replaceState({}, "", window.location.pathname);
    await loadFamilyServers(id);
    await loadChats(id, chat.family_id || currentFamily?.id || "");
    if (goHome) setScreen("home");
  }

  function familyMemberTotal() {
    if (!currentFamily) return 0;
    return familyMembers.filter((m) => m.family_id === currentFamily.id).length;
  }

  function familyDeleteYesCount() {
    return familyDeleteVotes.filter((v) => v.vote === "yes").length;
  }

  function familyDeleteNoCount() {
    return familyDeleteVotes.filter((v) => v.vote === "no").length;
  }

  function familyDeletePercent() {
    const total = familyMemberTotal();
    if (!total) return 0;
    return Math.round((familyDeleteYesCount() / total) * 100);
  }

  async function deleteCurrentFamilyForever(familyId: string) {
    await supabase
      .from("family_delete_votes")
      .delete()
      .eq("family_id", familyId);
    await supabase
      .from("family_delete_polls")
      .delete()
      .eq("family_id", familyId);
    await supabase.from("family_servers").delete().eq("id", familyId);

    if (currentFamily?.id === familyId) {
      if (typeof window !== "undefined")
        localStorage.removeItem(`family-feud-current-family-${userId}`);
      setCurrentFamily(null);
      setActiveFamilyDeletePoll(null);
      setFamilyDeleteVotes([]);
      await loadFamilyServers(userId);
      setChats([]);
      setHomeMessages([]);
      setScreen("home");
    }
  }

  async function finalizeFamilyDeletePoll(
    poll = activeFamilyDeletePoll,
    votes = familyDeleteVotes,
  ) {
    if (!poll || familyDeleteBusy) return;
    const total = familyMembers.filter(
      (m) => m.family_id === poll.family_id,
    ).length;
    if (!total) return;

    const yes = votes.filter((v) => v.vote === "yes").length;
    const voted = votes.length;
    const expired = new Date(poll.expires_at).getTime() <= Date.now();
    const everyoneVoted = voted >= total;
    const passed = yes / total >= 0.7;

    if (!expired && !everyoneVoted) return;

    if (passed) {
      setFamilyDeleteBusy(true);
      try {
        await deleteCurrentFamilyForever(poll.family_id);
        alert("The Family Feud was deleted after the vote passed.");
      } finally {
        setFamilyDeleteBusy(false);
      }
    } else {
      await supabase
        .from("family_delete_polls")
        .update({ status: "failed" })
        .eq("id", poll.id);
      setActiveFamilyDeletePoll(null);
      setFamilyDeleteVotes([]);
      alert("The delete vote did not pass.");
    }
  }

  async function loadActiveFamilyDeletePoll(
    familyId = currentFamily?.id || "",
  ) {
    if (!familyId) {
      setActiveFamilyDeletePoll(null);
      setFamilyDeleteVotes([]);
      return;
    }

    const { data: poll } = await supabase
      .from("family_delete_polls")
      .select("*")
      .eq("family_id", familyId)
      .eq("status", "active")
      .order("created_at", { ascending: false })
      .limit(1)
      .maybeSingle();

    if (!poll) {
      setActiveFamilyDeletePoll(null);
      setFamilyDeleteVotes([]);
      return;
    }

    const { data: votes } = await supabase
      .from("family_delete_votes")
      .select("*")
      .eq("poll_id", poll.id);
    setActiveFamilyDeletePoll(poll as FamilyDeletePoll);
    setFamilyDeleteVotes((votes || []) as FamilyDeleteVote[]);
    await finalizeFamilyDeletePoll(
      poll as FamilyDeletePoll,
      (votes || []) as FamilyDeleteVote[],
    );
  }

  async function startFamilyDeleteVote() {
    if (!currentFamily || !isFamilyAdmin())
      return alert("Only family admins can start a delete vote.");
    const ok = window.confirm(
      "Start a 24-hour vote to delete this entire Family Feud? If 70% or more vote yes, it will be permanently deleted.",
    );
    if (!ok) return;

    await loadActiveFamilyDeletePoll(currentFamily.id);
    if (activeFamilyDeletePoll)
      return alert("There is already an active delete vote.");

    const expiresAt = new Date(Date.now() + 24 * 60 * 60 * 1000).toISOString();
    const { data: poll, error } = await supabase
      .from("family_delete_polls")
      .insert({
        family_id: currentFamily.id,
        created_by: userId,
        expires_at: expiresAt,
        status: "active",
      })
      .select("*")
      .single();

    if (error || !poll)
      return alert(error?.message || "Could not start delete vote.");

    await supabase
      .from("family_delete_votes")
      .upsert({
        poll_id: poll.id,
        family_id: currentFamily.id,
        user_id: userId,
        vote: "yes",
      });

    const { data: mainChats } = await supabase
      .from("chats")
      .select("id")
      .eq("family_id", currentFamily.id)
      .eq("is_family", true)
      .limit(1);
    const mainChatId = mainChats?.[0]?.id;
    if (mainChatId) {
      await systemMessage(
        mainChatId,
        `${profileName(userId)} started a 24-hour vote to delete this Family Feud. 70% yes votes are required.`,
        "family_delete_vote",
      );
    }

    await loadActiveFamilyDeletePoll(currentFamily.id);
  }

  async function voteFamilyDelete(vote: "yes" | "no") {
    if (!activeFamilyDeletePoll || !currentFamily) return;
    await supabase.from("family_delete_votes").upsert({
      poll_id: activeFamilyDeletePoll.id,
      family_id: currentFamily.id,
      user_id: userId,
      vote,
    });
    await loadActiveFamilyDeletePoll(currentFamily.id);
  }

  async function selectFamilyServer(family: FamilyServer | null) {
    setFamilyMenuOpen(false);
    setCurrentFamily(family);
    setChats([]);
    setHomeMessages([]);
    setActiveChat(null);
    if (family && typeof window !== "undefined") {
      localStorage.setItem(`family-feud-current-family-${userId}`, family.id);
    }
    if (family) {
      await loadChats(userId, family.id);
      await loadActiveFamilyDeletePoll(family.id);
      await loadStories(family.id);
    }
  }

  async function refreshActiveChatData(
    chatId: string,
    options: { markRead?: boolean } = {},
  ) {
    const [{ data: nextMessages }, { data: nextReads }] = await Promise.all([
      supabase
        .from("messages")
        .select("*")
        .eq("chat_id", chatId)
        .order("created_at", { ascending: true }),
      supabase.from("message_reads").select("*").eq("chat_id", chatId),
    ]);

    if (nextMessages) setMessages(nextMessages as Message[]);
    if (nextReads) setActiveReadReceipts(nextReads as MessageRead[]);

    if (options.markRead && userId) {
      const now = new Date().toISOString();
      await supabase
        .from("message_reads")
        .upsert({ chat_id: chatId, user_id: userId, read_at: now });
      setChatReads((prev) => ({ ...prev, [chatId]: now }));
    }
  }

  async function openChat(chat: Chat) {
    setActiveChat(chat);
    setChatName(chat.name);
    setChatDescription(chat.description || "");
    setChatIcon(chat.icon_url || null);
    const localLook = getLocalChatLook(chat.id);
    setChatColor(localLook?.chatColor || chat.chat_color || "patriot");
    setChatBackground(
      localLook?.chatBackground || chat.chat_background || "patriot",
    );
    setInboundBubbleColor(
      localLook?.inboundBubbleColor || chat.inbound_bubble_color || "#18181b",
    );
    setInboundTextColor(
      localLook?.inboundTextColor || chat.inbound_text_color || "#ffffff",
    );
    setOwnTextColor(
      localLook?.ownTextColor || chat.own_text_color || "#ffffff",
    );
    setMessageInputBg(
      localLook?.messageInputBg || chat.message_input_bg || "#18181b",
    );
    setMessageInputText(
      localLook?.messageInputText || chat.message_input_text || "#ffffff",
    );
    setWallpaperBlur(
      Number(localLook?.wallpaperBlur ?? chat.wallpaper_blur ?? 0),
    );
    setScreen("chat");

    await loadChatMembers(chat.id);
    await refreshActiveChatData(chat.id, { markRead: true });
  }

  async function openChatSettings(chat: Chat) {
    setActiveChat(chat);
    setChatName(chat.direct_key ? chatTitle(chat) : chat.name);
    setChatDescription(chat.description || "");
    setChatIcon(chat.icon_url || null);
    const localLook = getLocalChatLook(chat.id);
    setChatColor(localLook?.chatColor || chat.chat_color || "patriot");
    setChatBackground(
      localLook?.chatBackground || chat.chat_background || "patriot",
    );
    setInboundBubbleColor(
      localLook?.inboundBubbleColor || chat.inbound_bubble_color || "#18181b",
    );
    setInboundTextColor(
      localLook?.inboundTextColor || chat.inbound_text_color || "#ffffff",
    );
    setOwnTextColor(
      localLook?.ownTextColor || chat.own_text_color || "#ffffff",
    );
    setMessageInputBg(
      localLook?.messageInputBg || chat.message_input_bg || "#18181b",
    );
    setMessageInputText(
      localLook?.messageInputText || chat.message_input_text || "#ffffff",
    );
    setWallpaperBlur(
      Number(localLook?.wallpaperBlur ?? chat.wallpaper_blur ?? 0),
    );

    const { data } = await supabase
      .from("chat_members")
      .select("*")
      .eq("chat_id", chat.id);
    if (data) {
      const members = data as ChatMember[];
      setChatMembers(members);
      const otherId = chat.direct_key
        ? members.find((m) => m.user_id !== userId)?.user_id || ""
        : "";
      setNicknameUserId(otherId);
      setDirectNickname(otherId ? profile?.nicknames?.[otherId] || "" : "");
    }

    setScreen("chatSettings");
  }

  async function systemMessage(chatId: string, text: string, type = "system") {
    await supabase.from("messages").insert({
      chat_id: chatId,
      user_id: userId || null,
      message: text,
      system_type: type,
    });
  }

  async function sendMessage() {
    if (
      !activeChat ||
      (!message.trim() && !pendingAttachments.length) ||
      !userId ||
      sendingMessage
    )
      return;

    const chatSnapshot = activeChat;
    const textToSend = message.trim();
    const attachmentsToSend = [...pendingAttachments];
    const completedAttachments = attachmentsToSend.filter(
      (item) => item.url && item.progress >= 100,
    );
    if (
      attachmentsToSend.length &&
      completedAttachments.length !== attachmentsToSend.length
    ) {
      alert("Wait for the photo or file to finish loading before sending.");
      return;
    }

    const gallery = completedAttachments.length > 1;
    const single = completedAttachments[0] || null;
    const optimisticId = -Date.now();
    const optimisticMessage: Message = {
      id: optimisticId,
      chat_id: chatSnapshot.id,
      user_id: userId,
      message: textToSend,
      created_at: new Date().toISOString(),
      edited_at: null,
      deleted_at: null,
      attachment_url: gallery
        ? JSON.stringify(
            completedAttachments.map(({ url, name, type }) => ({
              url,
              name,
              type,
            })),
          )
        : single?.url || null,
      attachment_name: gallery
        ? `${completedAttachments.length} attachments`
        : single?.name || null,
      attachment_type: gallery ? "gallery" : single?.type || null,
    };

    setSendingMessage(true);
    setMessage("");
    setPendingAttachments([]);
    setFailedDraft(null);
    setMessages((prev) => [...prev, optimisticMessage]);

    try {
      const { data, error } = await supabase
        .from("messages")
        .insert({
          chat_id: chatSnapshot.id,
          user_id: userId,
          message: textToSend,
          attachment_url: optimisticMessage.attachment_url,
          attachment_name: optimisticMessage.attachment_name,
          attachment_type: optimisticMessage.attachment_type,
        })
        .select("*")
        .single();

      if (error) {
        setMessages((prev) => prev.filter((m) => m.id !== optimisticId));
        setMessage(textToSend);
        setPendingAttachments(attachmentsToSend);
        setFailedDraft({ text: textToSend, attachments: attachmentsToSend });
        return;
      }

      if (data)
        setMessages((prev) =>
          prev.map((m) => (m.id === optimisticId ? (data as Message) : m)),
        );
      await stopTyping();
      loadChats();
    } catch {
      setMessages((prev) => prev.filter((m) => m.id !== optimisticId));
      setMessage(textToSend);
      setPendingAttachments(attachmentsToSend);
      setFailedDraft({ text: textToSend, attachments: attachmentsToSend });
    } finally {
      setSendingMessage(false);
    }
  }

  async function retryFailedMessage() {
    if (!failedDraft || !activeChat || sendingMessage) return;

    const textToSend = failedDraft.text;
    const attachmentsToSend = failedDraft.attachments;
    const completedAttachments = attachmentsToSend.filter(
      (item) => item.url && item.progress >= 100,
    );

    setFailedDraft(null);
    setSendingMessage(true);

    try {
      const gallery = completedAttachments.length > 1;
      const single = completedAttachments[0] || null;
      const { error } = await supabase.from("messages").insert({
        chat_id: activeChat.id,
        user_id: userId,
        message: textToSend,
        attachment_url: gallery
          ? JSON.stringify(
              completedAttachments.map(({ url, name, type }) => ({
                url,
                name,
                type,
              })),
            )
          : single?.url || null,
        attachment_name: gallery
          ? `${completedAttachments.length} attachments`
          : single?.name || null,
        attachment_type: gallery ? "gallery" : single?.type || null,
      });

      if (error) {
        setFailedDraft({ text: textToSend, attachments: attachmentsToSend });
        alert("Still failed to send. Try again.");
        return;
      }

      setMessage("");
      setPendingAttachments([]);
      await openChat(activeChat);
      await loadChats();
    } finally {
      setSendingMessage(false);
    }
  }

  async function startTyping(nextValue: string) {
    if (!activeChat || !profile || !nextValue.trim()) return;

    await supabase.from("typing_status").upsert({
      chat_id: activeChat.id,
      user_id: userId,
      display_name: profile.display_name,
      updated_at: new Date().toISOString(),
    });

    if (typingTimer.current) clearTimeout(typingTimer.current);
    typingTimer.current = setTimeout(() => stopTyping(), 1800);
  }

  async function stopTyping() {
    if (!activeChat || !userId) return;
    await supabase
      .from("typing_status")
      .delete()
      .eq("chat_id", activeChat.id)
      .eq("user_id", userId);
  }

  async function loadTypingUsers() {
    if (!activeChat) return;

    const cutoff = new Date(Date.now() - 3000).toISOString();

    const { data } = await supabase
      .from("typing_status")
      .select("*")
      .eq("chat_id", activeChat.id)
      .neq("user_id", userId)
      .gte("updated_at", cutoff);

    if (data) setTypingUsers(data as TypingUser[]);
  }

  async function editMessage(id: number) {
    if (!editingText.trim()) return;

    await supabase
      .from("messages")
      .update({
        message: editingText.trim(),
        edited_at: new Date().toISOString(),
      })
      .eq("id", id)
      .eq("user_id", userId);

    setEditingId(null);
    setEditingText("");
    if (activeChat) await openChat(activeChat);
  }

  async function deleteMessage(msg: Message) {
    if (!activeChat) return;

    const who = profileName(userId);

    await supabase
      .from("messages")
      .update({
        deleted_at: new Date().toISOString(),
        deleted_by_name: who,
        message: `${who} deleted a message`,
      })
      .eq("id", msg.id)
      .eq("user_id", userId);

    await openChat(activeChat);
  }

  async function openDirectChat(otherUserId: string) {
    if (!currentFamily) return alert("Create or join a family first.");
    const key = `${currentFamily.id}__${directKey(userId, otherUserId)}`;

    const { data: existing } = await supabase
      .from("chats")
      .select("*")
      .eq("direct_key", key)
      .eq("family_id", currentFamily.id)
      .maybeSingle();

    if (existing) {
      await openChat(existing as Chat);
      return;
    }

    const otherName = profileName(otherUserId);

    const { data: chat, error } = await supabase
      .from("chats")
      .insert({
        name: otherName,
        owner_id: userId,
        family_id: currentFamily.id,
        direct_key: key,
        chat_color: "patriot",
        chat_background: "smoke",
      })
      .select("*")
      .single();

    if (error || !chat) return alert(error?.message || "Could not create chat");

    await supabase.from("chat_members").insert([
      { chat_id: chat.id, user_id: userId, role: "owner" },
      { chat_id: chat.id, user_id: otherUserId, role: "member" },
    ]);

    await loadChats();
    await openChat(chat as Chat);
  }

  async function createGroupChat() {
    if (!currentFamily) return alert("Create or join a family first.");
    if (!newChatName.trim()) return alert("Name the group chat.");
    if (selectedPeople.length + 1 > 40) return alert("Max 40 people per chat.");

    const { data: chat, error } = await supabase
      .from("chats")
      .insert({
        name: newChatName.trim(),
        owner_id: userId,
        family_id: currentFamily.id,
        chat_color: "patriot",
        chat_background: "redblue",
      })
      .select("*")
      .single();

    if (error || !chat)
      return alert(error?.message || "Could not create group");

    const all = Array.from(new Set([userId, ...selectedPeople]));

    await supabase.from("chat_members").insert(
      all.map((id) => ({
        chat_id: chat.id,
        user_id: id,
        role: id === userId ? "owner" : "member",
      })),
    );

    await systemMessage(
      chat.id,
      `${profileName(userId)} created this chat`,
      "created",
    );

    setNewChatName("");
    setSelectedPeople([]);
    await loadChats();
    await openChat(chat as Chat);
  }

  async function addPersonToChat(personId: string) {
    if (!activeChat || !isAdmin()) return;
    if (isMember(personId)) return;

    await supabase.from("chat_members").upsert({
      chat_id: activeChat.id,
      user_id: personId,
      role: "member",
    });

    if (!activeChat.direct_key)
      await systemMessage(
        activeChat.id,
        `${profileName(userId)} added ${profileName(personId)}`,
        "member_added",
      );
    await loadChatMembers(activeChat.id);
  }

  async function removePersonFromChat(personId: string) {
    if (!activeChat || !isAdmin()) return;
    if (activeChat.is_family)
      return alert(
        "Family Chat members cannot be removed here. Only the app admin can block someone from the whole app.",
      );
    if (personId === userId) return alert("Use Leave Chat instead.");

    const targetRole = roleOf(personId);
    if ((targetRole === "admin" || targetRole === "owner") && !isOwner()) {
      return alert("Only the owner can remove admins or the owner.");
    }
    if (!isOwner() && targetRole !== "member") {
      return alert("Admins can only remove regular members.");
    }

    await supabase
      .from("chat_members")
      .delete()
      .eq("chat_id", activeChat.id)
      .eq("user_id", personId);
    if (!activeChat.direct_key)
      await systemMessage(
        activeChat.id,
        `${profileName(userId)} removed ${profileName(personId)}`,
        "member_removed",
      );
    await loadChatMembers(activeChat.id);
  }

  async function makeAdmin(personId: string) {
    if (!activeChat || !isOwner()) return;

    await supabase
      .from("chat_members")
      .update({ role: "admin" })
      .eq("chat_id", activeChat.id)
      .eq("user_id", personId);
    if (!activeChat.direct_key)
      await systemMessage(
        activeChat.id,
        `${profileName(userId)} made ${profileName(personId)} an admin`,
        "admin_added",
      );
    await loadChatMembers(activeChat.id);
  }

  async function removeAdmin(personId: string) {
    if (!activeChat || !isOwner()) return;

    await supabase
      .from("chat_members")
      .update({ role: "member" })
      .eq("chat_id", activeChat.id)
      .eq("user_id", personId);
    if (!activeChat.direct_key)
      await systemMessage(
        activeChat.id,
        `${profileName(userId)} removed admin from ${profileName(personId)}`,
        "admin_removed",
      );
    await loadChatMembers(activeChat.id);
  }

  async function transferOwner(personId: string) {
    if (!activeChat || !isOwner()) return;

    await supabase
      .from("chats")
      .update({ owner_id: personId })
      .eq("id", activeChat.id);
    await supabase
      .from("chat_members")
      .update({ role: "owner" })
      .eq("chat_id", activeChat.id)
      .eq("user_id", personId);
    await supabase
      .from("chat_members")
      .update({ role: "admin" })
      .eq("chat_id", activeChat.id)
      .eq("user_id", userId);
    if (!activeChat.direct_key)
      await systemMessage(
        activeChat.id,
        `${profileName(userId)} transferred ownership to ${profileName(personId)}`,
        "owner_transfer",
      );

    const { data } = await supabase
      .from("chats")
      .select("*")
      .eq("id", activeChat.id)
      .single();
    if (data) setActiveChat(data as Chat);
    await loadChatMembers(activeChat.id);
  }

  async function leaveChat() {
    if (!activeChat) return;
    if (activeChat.is_family) return alert("You cannot leave Family Chat.");

    await systemMessage(
      activeChat.id,
      `${profileName(userId)} left the chat`,
      "left",
    );
    await supabase
      .from("chat_members")
      .delete()
      .eq("chat_id", activeChat.id)
      .eq("user_id", userId);
    await loadChats();
    setScreen("home");
  }

  async function deleteChat() {
    if (!activeChat) return;
    if (activeChat.is_family) return alert("Family Chat cannot be deleted.");
    if (!activeChat.direct_key && !isOwner())
      return alert("Only the owner can delete this chat.");

    const yes = window.confirm(
      "Delete this chat forever? This permanently removes all messages from the server for everyone.",
    );
    if (!yes) return;

    await supabase.from("typing_status").delete().eq("chat_id", activeChat.id);
    await supabase.from("message_reads").delete().eq("chat_id", activeChat.id);
    await supabase.from("messages").delete().eq("chat_id", activeChat.id);
    await supabase.from("chat_members").delete().eq("chat_id", activeChat.id);
    const { error } = await supabase
      .from("chats")
      .delete()
      .eq("id", activeChat.id);

    if (error) return alert(error.message);

    setActiveChat(null);
    setMessages([]);
    await loadChats();
    setScreen("home");
  }

  async function saveProfileSettings() {
    if (!profile) return;

    const nextNicknames = { ...(profile.nicknames || {}) };
    if (nicknameUserId && nicknameValue.trim())
      nextNicknames[nicknameUserId] = nicknameValue.trim();

    const { data } = await supabase
      .from("profiles")
      .update({
        display_name: settingsName.trim(),
        about: settingsAbout.trim() || "Ready to feud",
        theme_color: settingsColor,
        chat_background: settingsBackground,
        home_background: settingsHomeBackground,
        avatar_url: settingsAvatar,
        app_scale: settingsAppScale,
        home_text_color: settingsHomeTextColor,
        home_panel_color: settingsHomePanelColor,
        home_wallpaper_blur: settingsHomeBlur,
        nicknames: nextNicknames,
      })
      .eq("id", profile.id)
      .select("*")
      .single();

    if (data) {
      setProfile(data as Profile);
      await loadProfiles();
      setSettingsSection("main");
      setFormNotice("Settings saved.");
    }
  }

  async function saveChatSettings() {
    if (!activeChat) return;

    saveLocalChatLook(activeChat.id);

    const updatePayload: Record<string, string | null> = {};
    if (isAdmin()) {
      updatePayload.name = chatName.trim() || activeChat.name;
      updatePayload.description = chatDescription;
      updatePayload.icon_url = chatIcon || null;
    }

    if (Object.keys(updatePayload).length) {
      const { data, error } = await supabase
        .from("chats")
        .update(updatePayload)
        .eq("id", activeChat.id)
        .select("*")
        .single();

      if (error) return alert(error.message);
      if (data) setActiveChat(data as Chat);
      if (data && activeChat.is_family && currentFamily && (isAdmin() || isFamilyAdmin())) {
        await supabase
          .from("family_servers")
          .update({
            name: updatePayload.name || chatName.trim() || currentFamily.name,
            icon_url: chatIcon || currentFamily.icon_url || null,
          })
          .eq("id", currentFamily.id);
        const refreshed = {
          ...currentFamily,
          name: String(
            updatePayload.name || chatName.trim() || currentFamily.name,
          ),
          icon_url: chatIcon || currentFamily.icon_url || null,
        };
        setCurrentFamily(refreshed);
        setFamilyServers((prev) =>
          prev.map((f) => (f.id === refreshed.id ? refreshed : f)),
        );
      }
    }

    await loadChats();
    alert("Chat look saved for you only.");
  }

  async function saveDirectNickname() {
    if (!profile || !nicknameUserId) return;

    const nextNicknames = { ...(profile.nicknames || {}) };
    if (directNickname.trim())
      nextNicknames[nicknameUserId] = directNickname.trim();
    else delete nextNicknames[nicknameUserId];

    const { data, error } = await supabase
      .from("profiles")
      .update({ nicknames: nextNicknames })
      .eq("id", profile.id)
      .select("*")
      .single();

    if (error) return alert(error.message);
    if (data) {
      setProfile(data as Profile);
      await loadProfiles();
      alert("Nickname saved.");
    }
  }

  function copyInvite(chat: Chat) {
    if (!isAdmin() && !isFamilyAdmin())
      return alert("Only family or chat admins can copy invite links.");
    if (chat.direct_key)
      return alert("Direct messages do not use invite links.");
    if (!chat.invite_code) return alert("No invite link yet.");

    navigator.clipboard.writeText(
      `${window.location.origin}?invite=${chat.invite_code}`,
    );
    alert("Invite link copied.");
  }

  async function blockUser(personId: string) {
    if (!isAppAdmin() || personId === userId) return;
    const { error } = await supabase
      .from("profiles")
      .update({
        is_blocked: true,
        blocked_at: new Date().toISOString(),
        blocked_by: userId,
      })
      .eq("id", personId);
    if (error) return alert(error.message);
    await loadProfiles();
  }

  async function unblockUser(personId: string) {
    if (!isAppAdmin()) return;
    const { error } = await supabase
      .from("profiles")
      .update({ is_blocked: false, blocked_at: null, blocked_by: null })
      .eq("id", personId);
    if (error) return alert(error.message);
    await loadProfiles();
  }

  async function removeUserFromApp(personId: string) {
    if (!isAppAdmin() || personId === userId) return;
    const yes = window.confirm(
      `Remove ${profileName(personId)} from every chat? Their messages stay unless you delete the chats.`,
    );
    if (!yes) return;
    const { error } = await supabase
      .from("chat_members")
      .delete()
      .eq("user_id", personId);
    if (error) return alert(error.message);
    await loadChats();
    await loadProfiles();
  }

  async function deleteMyAccount() {
    const typed = window.prompt(
      "Type DELETE to permanently delete your account data and sign out.",
    );
    if (typed !== "DELETE") return;
    const { error } = await supabase.rpc("delete_my_account");
    if (error) return alert(error.message);
    await supabase.auth.signOut();
    setScreen("auth");
  }

  function uploadImage(file: File, setter: (value: string) => void) {
    const reader = new FileReader();
    reader.onload = () => setter(String(reader.result || ""));
    reader.readAsDataURL(file);
  }

  function attachMessageFiles(files: FileList | File[]) {
    const list = Array.from(files || [])
      .filter(Boolean)
      .slice(0, 18);
    if (!list.length) return;
    list.forEach((file) => {
      const tempId = `${file.name}-${file.size}-${Date.now()}-${Math.random()}`;
      const base = {
        url: "",
        name: file.name,
        type: file.type || "file",
        progress: 1,
        tempId,
      } as {
        url: string;
        name: string;
        type: string;
        progress: number;
        tempId?: string;
      };
      setPendingAttachments((prev) => [...prev, base].slice(0, 18));
      const reader = new FileReader();
      reader.onprogress = (event) => {
        if (event.lengthComputable) {
          const progress = Math.max(
            1,
            Math.min(99, Math.round((event.loaded / event.total) * 100)),
          );
          setPendingAttachments((prev) =>
            prev.map((item: any) =>
              item.tempId === tempId ? { ...item, progress } : item,
            ),
          );
        }
      };
      reader.onload = () => {
        setPendingAttachments((prev) =>
          prev.map((item: any) =>
            item.tempId === tempId
              ? {
                  url: String(reader.result || ""),
                  name: file.name,
                  type: file.type || "file",
                  progress: 100,
                }
              : item,
          ),
        );
      };
      reader.onerror = () => {
        setPendingAttachments((prev) =>
          prev.filter((item: any) => item.tempId !== tempId),
        );
        alert(`${file.name} failed to load. Try again.`);
      };
      reader.readAsDataURL(file);
    });
  }

  function attachMessageFile(file: File) {
    attachMessageFiles([file]);
  }

  useEffect(() => {
    let mounted = true;
    const bootStartedAt = Date.now();

    const wait = (ms: number) => new Promise((resolve) => window.setTimeout(resolve, ms));
    const finishBoot = async (signedIn: boolean) => {
      if (!mounted) return;
      const minimumMs = signedIn ? 5000 : 850;
      const remaining = Math.max(0, minimumMs - (Date.now() - bootStartedAt));
      if (remaining > 0) await wait(remaining);
      if (!mounted) return;
      setBootProgress(100);
      setBootMessage(signedIn ? "Ready" : "Welcome");
      await wait(260);
      if (mounted) setAuthChecking(false);
    };

    const progressTimer = window.setInterval(() => {
      setBootProgress((current) => {
        if (current >= 92) return current;
        return Math.min(92, current + (current < 55 ? 4 : 1.8));
      });
    }, 180);

    supabase.auth.getSession().then(async ({ data }) => {
      if (!mounted) return;

      if (data.session?.user) {
        setBootMessage("Loading your family...");
        setBootProgress((current) => Math.max(current, 35));
        await loadAccount(data.session.user.id, true);
        if (!mounted) return;
        setScreen("home");
        setBootMessage("Opening chats...");
        setBootProgress((current) => Math.max(current, 94));
        await finishBoot(true);
      } else {
        setBootMessage("Welcome");
        setBootProgress(100);
        setScreen("auth");
        await finishBoot(false);
      }
    });

    const { data: listener } = supabase.auth.onAuthStateChange(
      async (event, session) => {
        if (!session?.user) {
          hasLoadedAccountRef.current = false;
          setUserId("");
          setUserEmail("");
          setProfile(null);
          setChats([]);
          setMessages([]);
          setActiveChat(null);
          setScreen("auth");
          setBootProgress(100);
          setAuthChecking(false);
          return;
        }

        if (event === "SIGNED_IN" && !hasLoadedAccountRef.current) {
          setAuthChecking(true);
          setBootProgress(18);
          setBootMessage("Signing you in...");
          const signInStartedAt = Date.now();
          await loadAccount(session.user.id, true);
          if (!mounted) return;
          const remaining = Math.max(0, 1100 - (Date.now() - signInStartedAt));
          if (remaining > 0) await wait(remaining);
          if (!mounted) return;
          setScreen("home");
          setBootProgress(100);
          setBootMessage("Ready");
          await wait(180);
          if (mounted) setAuthChecking(false);
          return;
        }

        setUserId(session.user.id);
        setUserEmail(session.user.email || "");
      },
    );

    return () => {
      mounted = false;
      window.clearInterval(progressTimer);
      listener.subscription.unsubscribe();
    };
  }, []);

  useEffect(() => {
    if (!currentFamily?.id) return;
    loadStories(currentFamily.id);
    const channel = supabase
      .channel(`stories-${currentFamily.id}`)
      .on("postgres_changes", { event: "*", schema: "public", table: "stories" }, () => loadStories(currentFamily.id))
      .on("postgres_changes", { event: "*", schema: "public", table: "story_views" }, () => loadStories(currentFamily.id))
      .subscribe();
    return () => {
      supabase.removeChannel(channel);
    };
  }, [currentFamily?.id, userId]);

  useEffect(() => {
    if (!activeChat) return;

    const channel = supabase
      .channel(`live-${activeChat.id}`)
      .on(
        "postgres_changes",
        { event: "*", schema: "public", table: "messages" },
        () =>
          refreshActiveChatData(activeChat.id, { markRead: screen === "chat" }),
      )
      .on(
        "postgres_changes",
        { event: "*", schema: "public", table: "typing_status" },
        () => loadTypingUsers(),
      )
      .subscribe();

    const interval = setInterval(loadTypingUsers, 1500);

    return () => {
      supabase.removeChannel(channel);
      clearInterval(interval);
    };
  }, [activeChat, userId]);

  useEffect(() => {
    function closeMenus() {
      setOpenMenu(null);
      setFamilyMenuOpen(false);
    }
    window.addEventListener("click", closeMenus);
    return () => window.removeEventListener("click", closeMenus);
  }, []);

  useEffect(() => {
    if (!currentFamily?.id) return;
    loadActiveFamilyDeletePoll(currentFamily.id);
    const interval = setInterval(
      () => loadActiveFamilyDeletePoll(currentFamily.id),
      30000,
    );
    return () => clearInterval(interval);
  }, [currentFamily?.id, familyMembers.length]);

  useEffect(() => {
    bottomRef.current?.scrollIntoView({ behavior: "smooth" });
  }, [messages]);



  if (storyDraftUrl) {
    const colorChoices = ["#ffffff", "#fde047", "#60a5fa", "#fb7185", "#34d399", "#c084fc", "#000000", "#f97316", "#22d3ee", "#f9a8d4", "#a3e635", "#e5e7eb"];
    const filterChoices = ["none", "warm", "cool", "cinema", "mono", "dream"];
    const activeTextItem = storyTextItems.find((item) => item.id === activeStoryTextId) || null;

    function toggleStoryTool(tool: "text" | "style" | "filter" | "move" | "manage") {
