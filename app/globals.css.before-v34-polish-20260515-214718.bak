@import "tailwindcss";

:root{color-scheme:dark}*{box-sizing:border-box}html,body{margin:0;min-height:100%;overflow-x:hidden;background:#020617}body{font-family:Arial,Helvetica,sans-serif}button,input,select,textarea{font:inherit}img,video{max-width:100%}::-webkit-scrollbar{width:0;height:0}

/* === FAMILY FEUD FIXED WALLPAPER / FIXED TOP / FIXED BOTTOM PATCH === */
html,
body {
  min-height: 100%;
  height: 100%;
  overflow-x: hidden;
  background: #020617;
  overscroll-behavior-y: none;
}

.ff-app-shell {
  position: relative !important;
  height: 100svh !important;
  min-height: 100svh !important;
  overflow: hidden !important;
  background: transparent !important;
}

.ff-fixed-wallpaper {
  position: fixed !important;
  inset: 0 !important;
  width: 100vw !important;
  height: 100svh !important;
  z-index: 0 !important;
  pointer-events: none !important;
  background-size: cover !important;
  background-position: center center !important;
  background-repeat: no-repeat !important;
  transform: translateZ(0);
}

.ff-fixed-wallpaper::after {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 18% 0%, rgba(190, 24, 93, .24), transparent 30%),
    radial-gradient(circle at 92% 8%, rgba(37, 99, 235, .30), transparent 36%),
    linear-gradient(180deg, rgba(0,0,0,.18), rgba(0,0,0,.52));
}

.ff-fixed-header {
  position: fixed !important;
  top: max(12px, env(safe-area-inset-top)) !important;
  left: 50% !important;
  transform: translateX(-50%) !important;
  width: min(94vw, 768px) !important;
  z-index: 99990 !important;
  margin: 0 !important;
}

.ff-scroll-lane {
  position: relative !important;
  z-index: 5 !important;
  height: 100svh !important;
  overflow-y: auto !important;
  overflow-x: hidden !important;
  -webkit-overflow-scrolling: touch !important;
  padding-left: 1rem !important;
  padding-right: 1rem !important;
  padding-top: calc(env(safe-area-inset-top) + 126px) !important;
  padding-bottom: calc(env(safe-area-inset-bottom) + 112px) !important;
  max-width: 768px !important;
  margin-left: auto !important;
  margin-right: auto !important;
  scrollbar-width: none;
}

.ff-scroll-lane::-webkit-scrollbar {
  display: none;
}

.ff-fixed-bottom-nav {
  position: fixed !important;
  left: 50% !important;
  bottom: calc(env(safe-area-inset-bottom) + 14px) !important;
  transform: translateX(-50%) !important;
  width: min(92vw, 430px) !important;
  z-index: 99995 !important;
  margin: 0 !important;
}

.ff-floating-new-chat {
  position: fixed !important;
  right: max(18px, env(safe-area-inset-right)) !important;
  bottom: calc(env(safe-area-inset-bottom) + 92px) !important;
  z-index: 99992 !important;
}

.ff-chat-topbar {
  position: fixed !important;
  top: 0 !important;
  left: 0 !important;
  right: 0 !important;
  z-index: 99990 !important;
}

.ff-chat-scroll-lane {
  position: relative !important;
  z-index: 5 !important;
  height: 100svh !important;
  overflow-y: auto !important;
  overflow-x: hidden !important;
  -webkit-overflow-scrolling: touch !important;
  padding-top: calc(env(safe-area-inset-top) + 96px) !important;
  padding-bottom: calc(env(safe-area-inset-bottom) + 94px) !important;
  max-width: 768px !important;
  margin: 0 auto !important;
  scrollbar-width: none;
}

.ff-chat-scroll-lane::-webkit-scrollbar {
  display: none;
}

.ff-chat-composer {
  position: fixed !important;
  left: 0 !important;
  right: 0 !important;
  bottom: 0 !important;
  z-index: 99990 !important;
}

/* Family Feud shell lock v27 */
html,
body {
  width: 100%;
  min-height: 100%;
  height: 100%;
  overflow: hidden;
  overscroll-behavior: none;
  background: #000;
}

body {
  position: fixed;
  inset: 0;
  touch-action: manipulation;
  -webkit-overflow-scrolling: touch;
}

#__next,
main {
  min-height: 100dvh;
}

* {
  -webkit-tap-highlight-color: transparent;
}
